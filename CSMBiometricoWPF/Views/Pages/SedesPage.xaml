<Page x:Class="CSMBiometricoWPF.Views.Pages.SedesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F7FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>  <!-- Header -->
            <RowDefinition Height="50"/>  <!-- Toolbar -->
            <RowDefinition Height="50"/>  <!-- Filtros -->
            <RowDefinition Height="*"/>   <!-- Grid -->
            <RowDefinition Height="35"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource PanelHeader}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#xE707;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                           Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="Sedes" Style="{StaticResource LblTituloHeader}"/>
            </StackPanel>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarAcciones}">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource BtnPrimario}"
                        Background="#009678" Height="35" Width="140" Margin="0,0,8,0"
                        Click="BtnNueva_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Nueva Sede" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource BtnSecundario}"
                        Width="110" Height="35"
                        Click="BtnRefrescar_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Refrescar" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Filtros -->
        <Border Grid.Row="2" Style="{StaticResource BarraFiltros}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Institución:" Style="{StaticResource LblFiltro}" Margin="0,0,8,0"/>
                <ComboBox x:Name="cmbInstitucion" Width="220" Height="28"
                          Style="{StaticResource CmbBase}"
                          SelectionChanged="CmbInstitucion_Changed"/>
                <CheckBox x:Name="chkMostrarInactivas" Content="Mostrar inactivas"
                          VerticalAlignment="Center" Margin="16,0,0,0" FontSize="12"
                          Checked="ChkMostrarInactivas_Changed" Unchecked="ChkMostrarInactivas_Changed"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <DataGrid x:Name="grid" Grid.Row="3"
                  Style="{StaticResource GridBase}"
                  ColumnHeaderStyle="{StaticResource GridHeaderStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"          Binding="{Binding IdSede}"          Width="50"/>
                <DataGridTextColumn Header="Nombre Sede" Binding="{Binding NombreSede}"       Width="*"/>
                <DataGridTextColumn Header="Institución" Binding="{Binding NombreInstitucion}" Width="160"/>
                <DataGridTextColumn Header="Dirección"   Binding="{Binding Direccion}"        Width="160"/>
                <DataGridTextColumn Header="Estado"      Binding="{Binding EstadoStr}"        Width="80"/>
                <DataGridTemplateColumn Header="" Width="65">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="✎" Background="Transparent" BorderThickness="0"
                                    Foreground="#007864" FontSize="16" Cursor="Hand"
                                    Click="BtnEditar_Click" Tag="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Background="Transparent" BorderThickness="0"
                                    Foreground="#FF9800" Cursor="Hand"
                                    Click="BtnHorarios_Click" Tag="{Binding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Horarios" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding LabelToggle}" Background="Transparent" BorderThickness="0"
                                    Foreground="#C62828" FontSize="15" Cursor="Hand"
                                    ToolTip="{Binding TooltipToggle}"
                                    Click="BtnToggleEstado_Click" Tag="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status bar -->
        <Border Grid.Row="4" Style="{StaticResource StatusBar}">
            <TextBlock x:Name="lblTotal" Text="Mostrando 0 registros"
                       VerticalAlignment="Center" FontSize="12"
                       HorizontalAlignment="Right"/>
        </Border>
    </Grid>
</Page>
