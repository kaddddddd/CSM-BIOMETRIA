<Window x:Class="CSMBiometricoWPF.Views.Dialogs.ConfirmarCierreDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cerrar panel"
        Width="420" Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#37474F" Padding="18,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                           Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Cerrar Panel de Ingresos"
                           FontFamily="Segoe UI Light" FontSize="17"
                           Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Contenido -->
        <StackPanel Grid.Row="1" Margin="24,18">
            <TextBlock Text="¿Desea cerrar el Panel de Ingresos?"
                       FontSize="13" Foreground="#424242"
                       TextWrapping="Wrap"/>
            <TextBlock Text="Se detendrá el lector biométrico y se cerrará la ventana."
                       FontSize="11" Foreground="#757575"
                       TextWrapping="Wrap" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Botones -->
        <Border Grid.Row="2" Background="White" Padding="16,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="-1" Opacity="0.08" Direction="90"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="Cancelar" Style="{StaticResource BtnSecundario}"
                        Width="90" Height="34" Margin="0,0,10,0"
                        Click="BtnCancelar_Click"/>
                <Button Content="Cerrar panel" Style="{StaticResource BtnPrimario}"
                        Width="110" Height="34"
                        Click="BtnCerrar_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
