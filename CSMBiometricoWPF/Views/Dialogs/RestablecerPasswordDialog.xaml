<Window x:Class="CSMBiometricoWPF.Views.Dialogs.RestablecerPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Restablecer contraseña"
        Width="400" Height="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#007864" Padding="18,0">
            <TextBlock Text="Restablecer contraseña"
                       FontFamily="Segoe UI Light" FontSize="18"
                       Foreground="White" VerticalAlignment="Center"/>
        </Border>

        <!-- Campos -->
        <StackPanel Grid.Row="1" Margin="24,20">
            <TextBlock Text="Para restablecer tu contraseña, ingresa tu usuario y la nueva contraseña."
                       FontSize="12" Foreground="#757575" TextWrapping="Wrap" Margin="0,0,0,18"/>

            <TextBlock Text="Usuario *" Style="{StaticResource LblCampo}"/>
            <TextBox x:Name="txtUsername" Height="34"
                     Style="{StaticResource TxtBase}" Margin="0,0,0,12"/>

            <TextBlock Text="Nueva contraseña *" Style="{StaticResource LblCampo}"/>
            <PasswordBox x:Name="pwdNueva" Height="34"
                         Style="{StaticResource PwdBase}" Margin="0,0,0,12"/>

            <TextBlock Text="Confirmar contraseña *" Style="{StaticResource LblCampo}"/>
            <PasswordBox x:Name="pwdConfirmar" Height="34"
                         Style="{StaticResource PwdBase}"/>
        </StackPanel>

        <!-- Botones -->
        <Border Grid.Row="2" Background="White" Padding="16,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="-1" Opacity="0.08" Direction="90"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="Cancelar" Style="{StaticResource BtnSecundario}"
                        Width="90" Height="34" Margin="0,0,10,0"
                        Click="BtnCancelar_Click"/>
                <Button Content="Cambiar" Style="{StaticResource BtnPrimario}"
                        Width="100" Height="34"
                        Click="BtnCambiar_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
