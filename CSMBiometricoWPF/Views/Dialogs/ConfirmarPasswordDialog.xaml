<Window x:Class="CSMBiometricoWPF.Views.Dialogs.ConfirmarPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirmar acción"
        Width="420"
        SizeToContent="Height"
        MinHeight="270"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#B71C1C" Padding="18,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                           Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Confirmar eliminación de huella"
                           FontFamily="Segoe UI Light" FontSize="17"
                           Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Contenido -->
        <StackPanel Grid.Row="1" Margin="24,18">
            <TextBlock x:Name="lblMensaje"
                       FontSize="12" Foreground="#424242"
                       TextWrapping="Wrap" Margin="0,0,0,16"/>

            <TextBlock Text="Ingresa tu contraseña para confirmar:" Style="{StaticResource LblCampo}"/>
            <PasswordBox x:Name="pwdConfirmar" Height="34"
                         Style="{StaticResource PwdBase}"
                         KeyDown="Pwd_KeyDown"/>

            <TextBlock x:Name="lblError" Text="" FontSize="11"
                       Foreground="#C62828" Margin="0,6,0,0" Visibility="Collapsed"/>
        </StackPanel>

        <!-- Botones -->
        <Border Grid.Row="2" Background="White" Padding="16,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="-1" Opacity="0.08" Direction="90"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="Cancelar" Style="{StaticResource BtnSecundario}"
                        Width="90" Height="34" Margin="0,0,10,0"
                        Click="BtnCancelar_Click"/>
                <Button Content="Confirmar" Style="{StaticResource BtnPeligro}"
                        Width="110" Height="34"
                        Click="BtnConfirmar_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
