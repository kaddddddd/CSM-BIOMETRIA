<Window x:Class="CSMBiometricoWPF.Views.PanelEntradaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panel de Ingresos — CSM Biométrico"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#F0F5F4"
        KeyDown="Window_KeyDown"
        Closing="Window_Closing">

    <!--
        Paleta:
          Verde principal  #007864
          Verde oscuro     #005A4A
          Verde claro bg   #E8F4F1
          Fondo general    #F0F5F4
          Panel izquierdo  #FFFFFF
          Tarjetas stats   #FFFFFF
          Texto primario   #1C3A33
          Texto secundario #607D8B
          Bordes suaves    #D4E6E1
    -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="72"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════
             ENCABEZADO  (verde principal)
             ══════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#007864">
            <Grid Margin="28,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + Institución -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="44" Height="44" CornerRadius="8"
                            Background="#005A4A" Margin="0,0,14,0">
                        <Image x:Name="imgLogo" Stretch="Uniform" Margin="7"/>
                    </Border>
                    <Rectangle Width="1" Margin="0,10,14,10" Fill="#FFFFFF" Opacity="0.25"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="lblInstitucion"
                                   FontFamily="Segoe UI Black" FontSize="18"
                                   Foreground="White"/>
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <Ellipse Width="5" Height="5" Fill="#A5D6A7"
                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock x:Name="lblSubtituloSede"
                                       Text="CONTROL DE ACCESO  ·  REGISTRO DE INGRESOS"
                                       FontFamily="Segoe UI" FontSize="10"
                                       Foreground="#B2DFDB"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Reloj -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="lblHora"
                               FontFamily="Consolas" FontSize="32" FontWeight="Bold"
                               Foreground="White" TextAlignment="Right"/>
                    <TextBlock x:Name="lblFecha"
                               FontFamily="Segoe UI" FontSize="10"
                               Foreground="#B2DFDB" TextAlignment="Right"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════
             CONTENIDO PRINCIPAL
             ══════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Panel izquierdo: Lector biométrico ─────────── -->
            <Border Grid.Column="0" Background="White"
                    BorderThickness="0,0,1,0" BorderBrush="#D4E6E1">
                <Grid>

                    <!-- Zona de identificación (estado inactivo) -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Margin="40,0">

                        <TextBlock Text="IDENTIFICACIÓN BIOMÉTRICA"
                                   FontFamily="Segoe UI SemiBold" FontSize="9"
                                   Foreground="#007864" TextAlignment="Center"
                                   Margin="0,0,0,36"/>

                        <!-- Círculo con huella y glow verde suave -->
                        <Border Width="180" Height="180" CornerRadius="90"
                                Background="#E8F4F1"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,28">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="32" ShadowDepth="0"
                                                  Color="#007864" Opacity="0.18"/>
                            </Border.Effect>
                            <Grid>
                                <Ellipse x:Name="elpPulso"
                                         Width="148" Height="148"
                                         Fill="#007864" Opacity="0.10"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                                <Image x:Name="imgHuellaPanel"
                                       Stretch="Uniform" Margin="28"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Grid>
                        </Border>

                        <!-- Instrucción -->
                        <TextBlock x:Name="lblInstruccionPanel"
                                   Text="Coloque su dedo en el sensor"
                                   FontFamily="Segoe UI SemiBold" FontSize="15"
                                   Foreground="#607D8B"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,28"/>

                        <!-- Píldora de estado del lector -->
                        <Border CornerRadius="20" Padding="18,8"
                                Background="#E8F4F1"
                                HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="dotLector" Width="8" Height="8"
                                         Fill="#9E9E9E" VerticalAlignment="Center"
                                         Margin="0,0,8,0"/>
                                <TextBlock x:Name="lblEstadoLector"
                                           Text="Inicializando..."
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="#607D8B"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Resultado de identificación (overlay del panel izquierdo) -->
                    <Border x:Name="pnlResultadoLector"
                            Visibility="Collapsed">
                        <Border.Background>
                            <SolidColorBrush x:Name="brushResultado" Color="#1B5E20"/>
                        </Border.Background>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Margin="40,0" MaxWidth="340">

                            <!-- Badge de estado -->
                            <Border x:Name="brdEstadoResult"
                                    CornerRadius="28" Padding="24,12"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,28">
                                <TextBlock x:Name="lblEstadoResult" Text=""
                                           FontFamily="Segoe UI Black" FontSize="15"
                                           Foreground="White" TextAlignment="Center"/>
                            </Border>

                            <!-- Nombre del estudiante -->
                            <TextBlock x:Name="lblNombreResult" Text=""
                                       FontFamily="Segoe UI Black" FontSize="26"
                                       Foreground="White"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,14"/>

                            <!-- Detalle -->
                            <TextBlock x:Name="lblDetalleResult" Text=""
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#B2DFDB"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </Grid>
            </Border>

            <!-- ── Panel derecho: Estadísticas + Lista ──────────── -->
            <Grid Grid.Column="1" Background="#F0F5F4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tarjetas de estadísticas horizontales -->
                <Grid Grid.Row="0" Margin="24,20,24,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total -->
                    <Border Grid.Column="0" CornerRadius="12" Background="White" Padding="20,16">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="1"
                                              Color="#007864" Opacity="0.08"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="TOTAL HOY"
                                       FontFamily="Segoe UI SemiBold" FontSize="9"
                                       Foreground="#007864" Margin="0,0,0,4"/>
                            <TextBlock x:Name="lblStatPresentes" Text="—"
                                       FontFamily="Segoe UI Black" FontSize="44"
                                       Foreground="#1C3A33"/>
                            <TextBlock Text="ingresos"
                                       FontFamily="Segoe UI" FontSize="10"
                                       Foreground="#90A4AE"/>
                        </StackPanel>
                    </Border>

                    <!-- A Tiempo -->
                    <Border Grid.Column="2" CornerRadius="12" Background="White" Padding="20,16">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="1"
                                              Color="#007864" Opacity="0.08"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="A TIEMPO"
                                       FontFamily="Segoe UI SemiBold" FontSize="9"
                                       Foreground="#2E7D32" Margin="0,0,0,4"/>
                            <TextBlock x:Name="lblStatATiempo" Text="0"
                                       FontFamily="Segoe UI Black" FontSize="44"
                                       Foreground="#2E7D32"/>
                            <TextBlock Text="puntuales"
                                       FontFamily="Segoe UI" FontSize="10"
                                       Foreground="#90A4AE"/>
                        </StackPanel>
                    </Border>

                    <!-- Tardanzas -->
                    <Border Grid.Column="4" CornerRadius="12" Background="White" Padding="20,16">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="1"
                                              Color="#007864" Opacity="0.08"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="TARDANZAS"
                                       FontFamily="Segoe UI SemiBold" FontSize="9"
                                       Foreground="#E65100" Margin="0,0,0,4"/>
                            <TextBlock x:Name="lblStatTardanzas" Text="0"
                                       FontFamily="Segoe UI Black" FontSize="44"
                                       Foreground="#E65100"/>
                            <TextBlock Text="llegadas tardías"
                                       FontFamily="Segoe UI" FontSize="10"
                                       Foreground="#90A4AE"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Cabecera de columnas -->
                <Border Grid.Row="1" Background="#E8F4F1"
                        BorderThickness="0,0,0,1" BorderBrush="#D4E6E1">
                    <Grid Margin="24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="84"/>
                            <ColumnDefinition Width="46"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="190"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="HORA" Grid.Column="0"
                                   FontFamily="Segoe UI SemiBold" FontSize="9"
                                   Foreground="#007864" VerticalAlignment="Center"/>
                        <TextBlock Text="ESTUDIANTE" Grid.Column="2"
                                   FontFamily="Segoe UI SemiBold" FontSize="9"
                                   Foreground="#007864" VerticalAlignment="Center"/>
                        <TextBlock Text="GRADO · GRUPO" Grid.Column="3"
                                   FontFamily="Segoe UI SemiBold" FontSize="9"
                                   Foreground="#007864" VerticalAlignment="Center"/>
                        <TextBlock Text="ESTADO" Grid.Column="4"
                                   FontFamily="Segoe UI SemiBold" FontSize="9"
                                   Foreground="#007864"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Lista de registros -->
                <ListView x:Name="listIngresos" Grid.Row="2"
                          Background="Transparent"
                          BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          AlternationCount="2">

                    <ListView.Resources>
                        <Style TargetType="ScrollBar">
                            <Setter Property="Width" Value="4"/>
                            <Setter Property="Background" Value="#D4E6E1"/>
                        </Style>
                    </ListView.Resources>

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="rowBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderThickness="0,0,0,1"
                                                BorderBrush="#EBF4F1">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                                <Setter TargetName="rowBorder"
                                                        Property="Background" Value="#F7FBFA"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="rowBorder"
                                                        Property="Background" Value="#EBF4F1"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="64" Margin="24,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="84"/>
                                    <ColumnDefinition Width="46"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="190"/>
                                    <ColumnDefinition Width="140"/>
                                </Grid.ColumnDefinitions>

                                <!-- Hora -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Hora}"
                                               FontFamily="Consolas" FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#37474F"/>
                                    <Border x:Name="badgeNuevo"
                                            Background="#E8F5E9" CornerRadius="3"
                                            Padding="5,1" HorizontalAlignment="Left"
                                            Visibility="{Binding BadgeNuevoVisibility}">
                                        <TextBlock Text="NUEVO"
                                                   FontFamily="Segoe UI SemiBold"
                                                   FontSize="8" Foreground="#2E7D32"/>
                                    </Border>
                                </StackPanel>

                                <!-- Avatar circular con iniciales -->
                                <Border Grid.Column="1"
                                        Width="34" Height="34"
                                        CornerRadius="17"
                                        Background="{Binding AvatarFondo}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Iniciales}"
                                               FontFamily="Segoe UI SemiBold"
                                               FontSize="12" Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- Nombre + Identificación -->
                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Margin="0,0,16,0">
                                    <TextBlock Text="{Binding Nombre}"
                                               FontFamily="Segoe UI SemiBold"
                                               FontSize="13"
                                               Foreground="#1C3A33"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Identificacion}"
                                               FontFamily="Segoe UI" FontSize="11"
                                               Foreground="#78909C"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- Grado · Grupo -->
                                <TextBlock Grid.Column="3"
                                           Text="{Binding GradoGrupo}"
                                           FontFamily="Segoe UI" FontSize="12"
                                           Foreground="#546E7A"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,16,0"/>

                                <!-- Pill de estado -->
                                <Border Grid.Column="4"
                                        Background="{Binding EstadoFondo}"
                                        BorderBrush="{Binding EstadoBorde}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="12,5"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        MinWidth="110">
                                    <TextBlock Text="{Binding EstadoTexto}"
                                               FontFamily="Segoe UI SemiBold"
                                               FontSize="10"
                                               Foreground="{Binding EstadoColor}"
                                               TextAlignment="Center"/>
                                </Border>

                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>

                </ListView>

                <!-- Mensaje cuando no hay registros -->
                <StackPanel x:Name="pnlSinDatos"
                            Grid.Row="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="&#x1F4CB;"
                               FontSize="56"
                               HorizontalAlignment="Center" Opacity="0.18"/>
                    <TextBlock Text="Sin ingresos registrados hoy"
                               FontFamily="Segoe UI Light" FontSize="20"
                               Foreground="#90A4AE"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0"/>
                    <TextBlock Text="Los registros aparecerán aquí en tiempo real"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="#B2DFDB"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════
             PIE DE PANTALLA
             ══════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="White"
                BorderThickness="0,1,0,0" BorderBrush="#D4E6E1">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Estado de conexión -->
                <Border x:Name="pnlConexion" Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="dotConexion" Width="6" Height="6"
                                 Fill="#4CAF50" VerticalAlignment="Center"
                                 Margin="0,0,6,0"/>
                        <TextBlock x:Name="lblConexion" Text="EN LÍNEA"
                                   FontFamily="Segoe UI SemiBold" FontSize="10"
                                   Foreground="#388E3C"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Última actualización -->
                <TextBlock x:Name="lblUltimaActualizacion"
                           Grid.Column="1"
                           FontFamily="Segoe UI" FontSize="10"
                           Foreground="#90A4AE"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>

                <!-- Atajos + botones icono -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="F6 cambiar sede  ·  F5 actualizar  ·  ESC cerrar"
                               FontFamily="Segoe UI" FontSize="10"
                               Foreground="#B0BEC5"
                               VerticalAlignment="Center"
                               Margin="0,0,14,0"/>
                    <Button x:Name="btnCambiarSede"
                            Height="24" Margin="0,0,6,0" Padding="8,0"
                            Click="BtnCambiarSede_Click" Cursor="Hand"
                            ToolTip="Cambiar sede"
                            Visibility="Collapsed">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="brd" CornerRadius="4" Background="#E8F4F1">
                                    <TextBlock Text="Cambiar sede" FontSize="10"
                                               FontFamily="Segoe UI SemiBold"
                                               Foreground="#007864"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Margin="8,0"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="brd" Property="Background" Value="#C8E6C9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Height="24" Width="24" Margin="0,0,6,0"
                            Click="BtnRefrescar_Click" Cursor="Hand"
                            ToolTip="Actualizar">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="brd" CornerRadius="4" Background="#E8F4F1">
                                    <TextBlock Text="&#x21BB;" FontSize="13"
                                               Foreground="#007864"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="brd" Property="Background" Value="#C8E6C9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Height="24" Width="24"
                            Click="BtnCerrar_Click" Cursor="Hand"
                            ToolTip="Cerrar panel">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="brd" CornerRadius="4" Background="#E8F4F1">
                                    <TextBlock Text="&#x2715;" FontSize="11"
                                               Foreground="#607D8B"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="brd" Property="Background" Value="#FFCDD2"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════
             OVERLAY: SELECTOR DE INSTITUCIÓN
             ══════════════════════════════════════════ -->
        <Grid x:Name="pnlSelectorInstitucion"
              Grid.RowSpan="3"
              Visibility="Collapsed">
            <Grid.Background>
                <SolidColorBrush Color="#E8F4F1" Opacity="0.94"/>
            </Grid.Background>

            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="460"
                    CornerRadius="16"
                    Background="White"
                    BorderBrush="#D4E6E1" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="0"
                                      Color="#007864" Opacity="0.12"/>
                </Border.Effect>

                <StackPanel Margin="36,32">

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Border Width="44" Height="44" CornerRadius="8"
                                Background="#007864" Margin="0,0,14,0">
                            <Image x:Name="imgLogoSelector" Stretch="Uniform" Margin="6"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="CSM BIOMÉTRICO"
                                       FontFamily="Segoe UI Black" FontSize="14"
                                       Foreground="#1C3A33"/>
                            <TextBlock Text="Panel de Control de Acceso"
                                       FontFamily="Segoe UI" FontSize="10"
                                       Foreground="#007864"/>
                        </StackPanel>
                    </StackPanel>

                    <Rectangle Height="1" Margin="0,0,0,24" Fill="#D4E6E1"/>

                    <TextBlock Text="Seleccionar institución"
                               FontFamily="Segoe UI SemiBold" FontSize="13"
                               Foreground="#546E7A" Margin="0,0,0,8"/>

                    <ComboBox x:Name="cmbInstitucionSelector"
                              Height="42"
                              FontFamily="Segoe UI" FontSize="14"
                              Foreground="#263238"
                              Margin="0,0,0,20"/>

                    <Button Content="Abrir Panel de Ingresos →"
                            Height="44"
                            FontFamily="Segoe UI SemiBold" FontSize="14"
                            Cursor="Hand"
                            Click="BtnAbrirPanel_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="brd" CornerRadius="10" Background="#007864">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      TextElement.Foreground="White"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="brd" Property="Background" Value="#009678"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="brd" Property="Background" Value="#005A4A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <TextBlock Text="También puede presionar Enter para confirmar"
                               FontFamily="Segoe UI" FontSize="10"
                               Foreground="#B0BEC5"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════
             OVERLAY: SELECTOR DE SEDE
             ══════════════════════════════════════════ -->
        <Grid x:Name="pnlSelectorSede"
              Grid.RowSpan="3"
              Visibility="Collapsed">
            <Grid.Background>
                <SolidColorBrush Color="#E8F4F1" Opacity="0.94"/>
            </Grid.Background>

            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="460"
                    CornerRadius="16"
                    Background="White"
                    BorderBrush="#D4E6E1" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="0"
                                      Color="#007864" Opacity="0.12"/>
                </Border.Effect>

                <StackPanel Margin="36,32">

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Border Width="44" Height="44" CornerRadius="8"
                                Background="#007864" Margin="0,0,14,0">
                            <TextBlock Text="&#x1F4CD;" FontSize="22"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="CSM BIOMÉTRICO"
                                       FontFamily="Segoe UI Black" FontSize="14"
                                       Foreground="#1C3A33"/>
                            <TextBlock Text="Seleccionar sede de trabajo"
                                       FontFamily="Segoe UI" FontSize="10"
                                       Foreground="#007864"/>
                        </StackPanel>
                    </StackPanel>

                    <Rectangle Height="1" Margin="0,0,0,24" Fill="#D4E6E1"/>

                    <TextBlock Text="Sede"
                               FontFamily="Segoe UI SemiBold" FontSize="13"
                               Foreground="#546E7A" Margin="0,0,0,8"/>

                    <ComboBox x:Name="cmbSedeSelector"
                              Height="42"
                              DisplayMemberPath="NombreSede"
                              FontFamily="Segoe UI" FontSize="14"
                              Foreground="#263238"
                              Margin="0,0,0,20"/>

                    <Button Content="Abrir Panel →"
                            Height="44"
                            FontFamily="Segoe UI SemiBold" FontSize="14"
                            Cursor="Hand"
                            Click="BtnAbrirPanelSede_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="brd" CornerRadius="10" Background="#007864">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      TextElement.Foreground="White"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="brd" Property="Background" Value="#009678"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="brd" Property="Background" Value="#005A4A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnCancelarSede"
                            Content="Cancelar"
                            Height="36"
                            FontFamily="Segoe UI" FontSize="13"
                            Cursor="Hand"
                            Click="BtnCancelarSede_Click"
                            Margin="0,8,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="brd" CornerRadius="10"
                                        Background="Transparent"
                                        BorderBrush="#D4E6E1" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      TextElement.Foreground="#607D8B"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="brd" Property="Background" Value="#F5F5F5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <TextBlock Text="También puede presionar Enter para confirmar"
                               FontFamily="Segoe UI" FontSize="10"
                               Foreground="#B0BEC5"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════
             OVERLAY: CONFIRMAR CIERRE
             ══════════════════════════════════════════ -->
        <Grid x:Name="pnlConfirmarCierre"
              Grid.RowSpan="3"
              Visibility="Collapsed">
            <Grid.Background>
                <SolidColorBrush Color="#263238" Opacity="0.55"/>
            </Grid.Background>

            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="420"
                    CornerRadius="12"
                    Background="White"
                    BorderBrush="#D4E6E1" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="0"
                                      Color="#000000" Opacity="0.18"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="52"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="52"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Background="#37474F"
                            CornerRadius="12,12,0,0" Padding="18,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="17"
                                       Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Cerrar Panel de Ingresos"
                                       FontFamily="Segoe UI Light" FontSize="16"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Mensaje -->
                    <StackPanel Grid.Row="1" Margin="24,18">
                        <TextBlock Text="¿Desea cerrar el Panel de Ingresos?"
                                   FontFamily="Segoe UI SemiBold" FontSize="13"
                                   Foreground="#1C3A33" TextWrapping="Wrap"/>
                        <TextBlock Text="Se detendrá el lector biométrico y se cerrará la ventana."
                                   FontFamily="Segoe UI" FontSize="11"
                                   Foreground="#607D8B" TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- Botones -->
                    <Border Grid.Row="2" Background="#F9FAFB"
                            CornerRadius="0,0,12,12"
                            BorderThickness="0,1,0,0" BorderBrush="#E8ECED"
                            Padding="16,0">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">

                            <!-- Cancelar -->
                            <Button Height="32" Width="90" Margin="0,0,10,0"
                                    Cursor="Hand" Click="BtnCancelarCierre_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="brd" CornerRadius="6"
                                                Background="#607D8B">
                                            <TextBlock Text="Cancelar"
                                                       FontFamily="Segoe UI SemiBold" FontSize="12"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="brd" Property="Background" Value="#546E7A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Cerrar panel -->
                            <Button Height="32" Width="110"
                                    Cursor="Hand" Click="BtnConfirmarCierre_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="brd" CornerRadius="6"
                                                Background="#007864">
                                            <TextBlock Text="Cerrar panel"
                                                       FontFamily="Segoe UI SemiBold" FontSize="12"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="brd" Property="Background" Value="#005A4A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>
