@startuml diagrama_casos_uso
title CSM Biometrico WPF - Diagrama de Casos de Uso

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam backgroundColor #FAFAFA
skinparam ArrowColor #444
skinparam ActorBorderColor #2C3E50
skinparam UsecaseBorderColor #2980B9
skinparam UsecaseBackgroundColor #EBF5FB

' ─── ACTORES ───────────────────────────────────────────────
actor "SUPERADMIN"     as SA  #C0392B
actor "ADMINISTRADOR"  as ADM #1F618D
actor "OPERADOR"       as OP  #1E8449
actor "Estudiante\n(Huella Biométrica)" as EST #7D3C98

' ─── SISTEMA EXTERNO ────────────────────────────────────────
actor "Lector\nDigitalPersona U.are.U" as LECTOR #888

' ─── PAQUETES POR MÓDULO ───────────────────────────────────

package "Autenticación y Sesión" {
    usecase "Iniciar sesión\n(usuario + institución)" as UC_LOGIN
    usecase "Cerrar sesión"                            as UC_LOGOUT
    usecase "Restablecer contraseña"                   as UC_RESET_PASS
}

package "Dashboard" {
    usecase "Ver estadísticas del día\n(presentes, tardanzas, ausentes)" as UC_DASH
}

package "Registro Biométrico" {
    usecase "Identificar huella 1:N\n(modo verificación)"  as UC_VERIF
    usecase "Registrar ingreso\nautomáticamente"           as UC_REG_ING
    usecase "Operar en modo Kiosk\n(solo huella, sin login)" as UC_KIOSK
    usecase "Panel de entrada\n(monitor en tiempo real)"   as UC_PANEL
}

package "Enrolamiento" {
    usecase "Enrolar huellas\n(4 muestras por dedo)"  as UC_ENROL
    usecase "Capturar imagen\nde huella"               as UC_CAPTURA
    usecase "Eliminar huella\nenrolada"                as UC_DEL_HUELLA
}

package "Gestión de Estudiantes" {
    usecase "Crear / Editar\nestudiante"    as UC_EST_CRUD
    usecase "Consultar asistencia\npor estudiante" as UC_CONSULTA
    usecase "Buscar / Filtrar\nestudiantes" as UC_EST_BUSCAR
}

package "Gestión Institucional" {
    usecase "Gestionar instituciones"  as UC_INST
    usecase "Gestionar sedes"          as UC_SEDE
    usecase "Gestionar grados"         as UC_GRADO
    usecase "Gestionar grupos"         as UC_GRUPO
    usecase "Configurar horarios\ny franjas"    as UC_HORARIO
    usecase "Configurar excepciones\nde horario" as UC_EXCEP
    usecase "Gestionar períodos\nacadémicos"    as UC_PERIODO
}

package "Usuarios del Sistema" {
    usecase "Crear / Editar usuarios\n(CRUD)"         as UC_USR_CRUD
    usecase "Asignar rol\ne institución"              as UC_USR_ROL
    usecase "Bloquear / Desbloquear\nusuario"         as UC_USR_BLOCK
}

package "Reportes y Auditoría" {
    usecase "Generar reporte\nde asistencia"    as UC_REPORTE
    usecase "Exportar a Excel\n(ClosedXML)"     as UC_EXCEL
    usecase "Consultar log\ndel sistema"        as UC_LOG
    usecase "Probar lector\nbiométrico"         as UC_TEST_LECT
}

package "Modo Offline" {
    usecase "Guardar registro\noffline (JSON)"     as UC_OFFLINE
    usecase "Sincronizar registros\npendientes"    as UC_SYNC
}

' ─── RELACIONES ACTORES ───────────────────────────────────

' SUPERADMIN (acceso total)
SA --> UC_LOGIN
SA --> UC_DASH
SA --> UC_VERIF
SA --> UC_ENROL
SA --> UC_DEL_HUELLA
SA --> UC_EST_CRUD
SA --> UC_CONSULTA
SA --> UC_INST
SA --> UC_SEDE
SA --> UC_GRADO
SA --> UC_GRUPO
SA --> UC_HORARIO
SA --> UC_EXCEP
SA --> UC_PERIODO
SA --> UC_USR_CRUD
SA --> UC_USR_ROL
SA --> UC_USR_BLOCK
SA --> UC_REPORTE
SA --> UC_EXCEL
SA --> UC_LOG
SA --> UC_TEST_LECT
SA --> UC_SYNC

' ADMINISTRADOR
ADM --> UC_LOGIN
ADM --> UC_DASH
ADM --> UC_VERIF
ADM --> UC_ENROL
ADM --> UC_DEL_HUELLA
ADM --> UC_EST_CRUD
ADM --> UC_CONSULTA
ADM --> UC_INST
ADM --> UC_GRADO
ADM --> UC_GRUPO
ADM --> UC_HORARIO
ADM --> UC_EXCEP
ADM --> UC_PERIODO
ADM --> UC_REPORTE
ADM --> UC_EXCEL
ADM --> UC_LOG
ADM --> UC_TEST_LECT

' OPERADOR
OP --> UC_LOGIN
OP --> UC_DASH
OP --> UC_VERIF
OP --> UC_CONSULTA
OP --> UC_TEST_LECT

' Estudiante interactúa con el lector
EST --> UC_KIOSK
EST --> UC_PANEL

' Lector biométrico
LECTOR --> UC_CAPTURA
UC_CAPTURA ..> UC_ENROL   : <<include>>
UC_CAPTURA ..> UC_VERIF   : <<include>>
UC_VERIF   ..> UC_REG_ING : <<include>>
UC_REG_ING ..> UC_OFFLINE : <<extend>>\n[sin conexión]
UC_LOGOUT  ..> UC_LOGIN   : <<extend>>
UC_RESET_PASS ..> UC_USR_CRUD : <<include>>
UC_EXCEL   ..> UC_REPORTE : <<include>>

@enduml
