<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <connectionStrings>
    <!--
      Configurar con la IP de la PC de la oficina donde está MySQL instalado.
      Ejemplo:  Server=192.168.1.10;Port=3306;Database=csm_biometrico;User ID=csm_user;Password=csm_pass;CharSet=utf8mb4;SslMode=None;
    -->
    <add name="MySqlConnection"
         connectionString="Server=127.0.0.1;Port=3306;Database=csm_biometrico;User ID=csm_user;Password=csm_pass;CharSet=utf8mb4;SslMode=None;AllowPublicKeyRetrieval=True;"
         providerName="MySqlConnector" />
  </connectionStrings>
  <appSettings>
    <add key="AppNombre" value="CSM Biométrico" />
    <add key="AppVersion" value="2.0.0" />
    <add key="UmbralCalidadHuella" value="60" />
    <add key="UmbralComparacionBiometrica" value="0.4" />
    <add key="MuestrasEnrolamiento" value="4" />
    <add key="ArchivoOffline" value="offline_records.json" />
    <add key="IntervaloSincronizacion" value="300" />
    <add key="MaxIntentosFallidos" value="5" />
    <add key="TiempoBloqueo" value="30" />
    <add key="NivelLogMinimo" value="INFO" />
    <add key="RotarLogsdias" value="30" />
    <!-- ID de institución para modo kiosk (0 = sin filtro) -->
    <add key="KioskIdInstitucion" value="0" />
  </appSettings>
</configuration>
