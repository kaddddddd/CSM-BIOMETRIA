<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Colores del sistema ──────────────────────────────── -->
    <Color x:Key="ColorVerdePrimario">#007864</Color>
    <Color x:Key="ColorVerdeClaro">#009678</Color>
    <Color x:Key="ColorVerdeMuyClaro">#00B491</Color>
    <Color x:Key="ColorVerdeOscuro">#005040</Color>
    <Color x:Key="ColorFondoDark">#263238</Color>
    <Color x:Key="ColorFondoMedio">#37474F</Color>
    <Color x:Key="ColorFondoClaro">#F5F7FA</Color>
    <Color x:Key="ColorAccentLime">#8BC34A</Color>
    <Color x:Key="ColorTexto">#1E2831</Color>
    <Color x:Key="ColorGris">#9E9E9E</Color>
    <Color x:Key="ColorError">#DC3232</Color>

    <SolidColorBrush x:Key="BrushVerdePrimario"  Color="{StaticResource ColorVerdePrimario}"/>
    <SolidColorBrush x:Key="BrushVerdeClaro"     Color="{StaticResource ColorVerdeClaro}"/>
    <SolidColorBrush x:Key="BrushVerdeMuyClaro"  Color="{StaticResource ColorVerdeMuyClaro}"/>
    <SolidColorBrush x:Key="BrushVerdeOscuro"    Color="{StaticResource ColorVerdeOscuro}"/>
    <SolidColorBrush x:Key="BrushFondoDark"      Color="{StaticResource ColorFondoDark}"/>
    <SolidColorBrush x:Key="BrushFondoMedio"     Color="{StaticResource ColorFondoMedio}"/>
    <SolidColorBrush x:Key="BrushFondoClaro"     Color="{StaticResource ColorFondoClaro}"/>
    <SolidColorBrush x:Key="BrushAccentLime"     Color="{StaticResource ColorAccentLime}"/>
    <SolidColorBrush x:Key="BrushTexto"          Color="{StaticResource ColorTexto}"/>
    <SolidColorBrush x:Key="BrushGris"           Color="{StaticResource ColorGris}"/>
    <SolidColorBrush x:Key="BrushError"          Color="{StaticResource ColorError}"/>
    <SolidColorBrush x:Key="BrushBlanco"         Color="White"/>
    <SolidColorBrush x:Key="BrushTransparente"   Color="Transparent"/>

    <!-- ── Estilo base de botón primario (verde) ─────────────── -->
    <!-- Usa overlay transparente para hover/pressed, así los estilos derivados
         heredan el efecto sin necesidad de sobreescribir colores en la plantilla -->
    <Style x:Key="BtnPrimario" TargetType="Button">
        <Setter Property="Background"   Value="{StaticResource BrushVerdeClaro}"/>
        <Setter Property="Foreground"   Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"      Value="14,8"/>
        <Setter Property="FontFamily"   Value="Segoe UI"/>
        <Setter Property="FontSize"     Value="13"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
        <Setter Property="Cursor"       Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                        <Grid>
                            <!-- Overlay cubre el botón completo incluyendo padding -->
                            <Border x:Name="overlay" CornerRadius="4" Background="Transparent"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="overlay" Property="Background" Value="#25FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="overlay" Property="Background" Value="#35000000"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="#BDBDBD"/>
                            <Setter Property="Foreground" Value="#757575"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Botón gris (secundario) ──────────────────────────── -->
    <Style x:Key="BtnSecundario" TargetType="Button" BasedOn="{StaticResource BtnPrimario}">
        <Setter Property="Background" Value="#607D8B"/>
    </Style>

    <!-- ── Botón rojo (peligro) ──────────────────────────────── -->
    <Style x:Key="BtnPeligro" TargetType="Button" BasedOn="{StaticResource BtnPrimario}">
        <Setter Property="Background" Value="#C62828"/>
    </Style>

    <!-- ── Botón naranja ─────────────────────────────────────── -->
    <Style x:Key="BtnNaranja" TargetType="Button" BasedOn="{StaticResource BtnPrimario}">
        <Setter Property="Background" Value="#FF9800"/>
    </Style>

    <!-- ── TextBox estilizado ───────────────────────────────── -->
    <Style x:Key="TxtBase" TargetType="TextBox">
        <Setter Property="FontFamily"           Value="Segoe UI"/>
        <Setter Property="FontSize"             Value="13"/>
        <Setter Property="Padding"              Value="8,0"/>
        <Setter Property="BorderBrush"          Value="#BDBDBD"/>
        <Setter Property="BorderThickness"      Value="1"/>
        <Setter Property="Background"           Value="White"/>
        <Setter Property="Foreground"           Value="{StaticResource BrushTexto}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushVerdePrimario}"/>
                            <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── PasswordBox estilizado ───────────────────────────── -->
    <Style x:Key="PwdBase" TargetType="PasswordBox">
        <Setter Property="FontFamily"           Value="Segoe UI"/>
        <Setter Property="FontSize"             Value="13"/>
        <Setter Property="Padding"              Value="8,0"/>
        <Setter Property="BorderBrush"          Value="#BDBDBD"/>
        <Setter Property="BorderThickness"      Value="1"/>
        <Setter Property="Background"           Value="White"/>
        <Setter Property="Foreground"           Value="{StaticResource BrushTexto}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushVerdePrimario}"/>
                            <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── ComboBox estilizado ──────────────────────────────── -->
    <Style x:Key="CmbBase" TargetType="ComboBox">
        <Setter Property="FontFamily"               Value="Segoe UI"/>
        <Setter Property="FontSize"                 Value="13"/>
        <Setter Property="Height"                   Value="34"/>
        <Setter Property="Background"               Value="White"/>
        <Setter Property="Foreground"               Value="{StaticResource BrushTexto}"/>
        <Setter Property="BorderBrush"              Value="#BDBDBD"/>
        <Setter Property="BorderThickness"          Value="1"/>
        <Setter Property="Padding"                  Value="8,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="MaxDropDownHeight"        Value="300"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility"   Value="Auto"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <!-- Botón toggle que cubre todo el control y dibuja el borde -->
                        <ToggleButton x:Name="PART_ToggleButton"
                                      Focusable="False" ClickMode="Press"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                  RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="bd"
                                            Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                            BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                            BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                        <Path x:Name="arrow"
                                              Data="M 0 0 L 4 4 L 8 0 Z"
                                              Fill="#767676" Width="8" Height="5"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Margin="0,0,10,0"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="BorderBrush" Value="#9E9E9E"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource BrushVerdePrimario}"/>
                                            <Setter TargetName="bd" Property="BorderThickness" Value="2"/>
                                            <Setter TargetName="arrow" Property="Fill" Value="{StaticResource BrushVerdePrimario}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <!-- Contenido seleccionado (modo no editable) -->
                        <ContentPresenter x:Name="contentPresenter"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                          Margin="8,0,28,0"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          HorizontalAlignment="Left"
                                          IsHitTestVisible="False"/>

                        <!-- Campo de texto (modo editable) -->
                        <TextBox x:Name="PART_EditableTextBox"
                                 Background="Transparent" BorderThickness="0"
                                 Margin="8,0,28,0"
                                 VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                 IsReadOnly="{TemplateBinding IsReadOnly}"
                                 Visibility="Hidden"/>

                        <!-- Popup desplegable -->
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom" Focusable="False">
                            <Border Background="White"
                                    BorderBrush="#BDBDBD" BorderThickness="1"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.12" Direction="270"/>
                                </Border.Effect>
                                <ScrollViewer CanContentScroll="True">
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="contentPresenter" Property="Visibility" Value="Hidden"/>
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── ComboBoxItem estilizado ──────────────────────────── -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="FontFamily"  Value="Segoe UI"/>
        <Setter Property="FontSize"    Value="13"/>
        <Setter Property="Padding"     Value="10,7"/>
        <Setter Property="Background"  Value="White"/>
        <Setter Property="Foreground"  Value="{StaticResource BrushTexto}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#E8F5F2"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#C8E6E0"/>
                            <Setter Property="Foreground" Value="#003828"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── DataGrid estilizado ──────────────────────────────── -->
    <Style x:Key="GridBase" TargetType="DataGrid">
        <Setter Property="Background"           Value="White"/>
        <Setter Property="BorderThickness"      Value="0"/>
        <Setter Property="RowHeaderWidth"       Value="0"/>
        <Setter Property="GridLinesVisibility"  Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#EEEEEE"/>
        <Setter Property="AlternatingRowBackground" Value="#F8FCFA"/>
        <Setter Property="SelectionMode"        Value="Single"/>
        <Setter Property="SelectionUnit"        Value="FullRow"/>
        <Setter Property="AutoGenerateColumns"  Value="False"/>
        <Setter Property="CanUserAddRows"       Value="False"/>
        <Setter Property="CanUserDeleteRows"    Value="False"/>
        <Setter Property="IsReadOnly"           Value="True"/>
        <Setter Property="FontFamily"           Value="Segoe UI"/>
        <Setter Property="FontSize"             Value="13"/>
        <Setter Property="RowHeight"            Value="40"/>
        <Setter Property="ColumnHeaderHeight"   Value="38"/>
        <Setter Property="RowStyle">
            <Setter.Value>
                <Style TargetType="DataGridRow">
                    <Setter Property="Foreground" Value="#263238"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#C8E6E0"/>
                            <Setter Property="Foreground" Value="#003828"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#E8F5F2"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Setter.Value>
        </Setter>
        <!-- Asegura que las celdas no sobreescriban el foreground de la fila -->
        <Setter Property="CellStyle">
            <Setter.Value>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding"         Value="4,0"/>
                    <Setter Property="Foreground"      Value="#263238"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background"  Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Foreground"  Value="#003828"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Estilo de header del DataGrid ────────────────────── -->
    <Style x:Key="GridHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="Background"   Value="{StaticResource BrushVerdePrimario}"/>
        <Setter Property="Foreground"   Value="White"/>
        <Setter Property="FontFamily"   Value="Segoe UI"/>
        <Setter Property="FontSize"     Value="13"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
        <Setter Property="Padding"      Value="10,0"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
        <Setter Property="BorderBrush"  Value="#005040"/>
        <Setter Property="Height"       Value="38"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridColumnHeader">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Panel de cabecera verde (header de cada página) ───── -->
    <Style x:Key="PanelHeader" TargetType="Border">
        <Setter Property="Background"  Value="{StaticResource BrushVerdePrimario}"/>
        <Setter Property="Padding"     Value="20,0"/>
        <Setter Property="Height"      Value="60"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="8" ShadowDepth="3" Opacity="0.18" Direction="270"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Texto de título en header ─────────────────────────── -->
    <Style x:Key="LblTituloHeader" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="Segoe UI Light"/>
        <Setter Property="FontSize"    Value="20"/>
        <Setter Property="Foreground"  Value="White"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ── Texto de subtítulo en header ──────────────────────── -->
    <Style x:Key="LblSubtituloHeader" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="Segoe UI"/>
        <Setter Property="FontSize"    Value="12"/>
        <Setter Property="Foreground"  Value="#B0E8DE"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Opacity"     Value="0.85"/>
    </Style>

    <!-- ── Label de campo de formulario ──────────────────────── -->
    <Style x:Key="LblCampo" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="Segoe UI"/>
        <Setter Property="FontSize"    Value="11"/>
        <Setter Property="Foreground"  Value="#757575"/>
        <Setter Property="Margin"      Value="0,0,0,4"/>
    </Style>

    <!-- ── Label de filtro en barra de búsqueda ──────────────── -->
    <Style x:Key="LblFiltro" TargetType="TextBlock">
        <Setter Property="FontFamily"        Value="Segoe UI"/>
        <Setter Property="FontSize"          Value="12"/>
        <Setter Property="FontWeight"        Value="SemiBold"/>
        <Setter Property="Foreground"        Value="#374151"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ── Texto de barra de estado (pie de página) ───────────── -->
    <Style x:Key="LblStatus" TargetType="TextBlock">
        <Setter Property="FontFamily"        Value="Segoe UI"/>
        <Setter Property="FontSize"          Value="11"/>
        <Setter Property="Foreground"        Value="#78909C"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ── Separador horizontal ──────────────────────────────── -->
    <Style x:Key="Separador" TargetType="Border">
        <Setter Property="Height"      Value="1"/>
        <Setter Property="Background"  Value="#E0E0E0"/>
        <Setter Property="Margin"      Value="0,8"/>
    </Style>

    <!-- ── Card blanca con sombra suave ──────────────────────── -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background"    Value="White"/>
        <Setter Property="CornerRadius"  Value="6"/>
        <Setter Property="Padding"       Value="16"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.10" Color="Black"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Botón de categoría del menú ──────────────────────── -->
    <Style x:Key="BtnMenuCategoria" TargetType="Button">
        <Setter Property="Background"      Value="White"/>
        <Setter Property="Foreground"      Value="#263238"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush"     Value="#EEEEEE"/>
        <Setter Property="Padding"         Value="12,0,12,0"/>
        <Setter Property="Height"          Value="44"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="FontFamily"      Value="Segoe UI Semibold"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Border x:Name="overlay" Background="Transparent"/>
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#EEF3FC"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#DCE8F8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Botón de acción derecha del menú ──────────────────── -->
    <Style x:Key="BtnMenuAccionDer" TargetType="Button">
        <Setter Property="Background"      Value="White"/>
        <Setter Property="Foreground"      Value="#263238"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush"     Value="#EEEEEE"/>
        <Setter Property="Padding"         Value="14,0"/>
        <Setter Property="Height"          Value="40"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid>
                            <Border x:Name="overlay" Background="Transparent"/>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="overlay" Property="Background" Value="#101E3464"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="overlay" Property="Background" Value="#201E3464"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Botón de acción peligro derecha del menú ──────────── -->
    <Style x:Key="BtnMenuAccionDerPeligro" TargetType="Button"
           BasedOn="{StaticResource BtnMenuAccionDer}">
        <Setter Property="Foreground" Value="#C62828"/>
    </Style>

    <!-- ── Botón de ítem dentro del popup de menú ───────────── -->
    <Style x:Key="BtnMenuPopup" TargetType="Button">
        <Setter Property="Background"      Value="White"/>
        <Setter Property="Foreground"      Value="{StaticResource BrushTexto}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="40,0,16,0"/>
        <Setter Property="Height"          Value="38"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderThickness="3,0,0,0"
                            BorderBrush="Transparent">
                        <Grid>
                            <Border x:Name="overlay" Background="Transparent"/>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="overlay" Property="Background" Value="#10007864"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="#007864"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="overlay" Property="Background" Value="#20007864"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Botón de acceso rápido (barra inferior) ─────────────── -->
    <Style x:Key="BtnAccesoRapido" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderBrush"     Value="#70FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="Height"          Value="30"/>
        <Setter Property="Padding"         Value="10,0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#30FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#50FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Barra de filtros (fondo limpio con línea inferior) ─── -->
    <Style x:Key="BarraFiltros" TargetType="Border">
        <Setter Property="Background"      Value="White"/>
        <Setter Property="Padding"         Value="20,0"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush"     Value="#E5E7EB"/>
    </Style>

    <!-- ── Toolbar de acciones (botones Nuevo, Refrescar, etc.) ─ -->
    <Style x:Key="ToolbarAcciones" TargetType="Border">
        <Setter Property="Background"      Value="White"/>
        <Setter Property="Padding"         Value="12,8"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush"     Value="#E5E7EB"/>
    </Style>

    <!-- ── Barra de estado (pie de página) ───────────────────── -->
    <Style x:Key="StatusBar" TargetType="Border">
        <Setter Property="Background"      Value="White"/>
        <Setter Property="Padding"         Value="16,0"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
        <Setter Property="BorderBrush"     Value="#E5E7EB"/>
    </Style>

    <!-- ── Botón categoría del sidebar permanente ───────────── -->
    <Style x:Key="BtnSidebarCategoria" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="#333333"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush"     Value="#D8D8D8"/>
        <Setter Property="Padding"         Value="16,0"/>
        <Setter Property="Height"          Value="46"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="FontFamily"      Value="Segoe UI Semibold"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#E0E0E0"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#D4D4D4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Botón ítem del sidebar permanente ─────────────────── -->
    <Style x:Key="BtnSidebarItem" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="#444444"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="44,0,16,0"/>
        <Setter Property="Height"          Value="38"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderThickness="3,0,0,0"
                            BorderBrush="Transparent">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#E0E0E0"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="#1ABC9C"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#D0D0D0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Botón de control de ventana (minimizar / maximizar) ─ -->
    <Style x:Key="BtnVentana" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="Width"           Value="42"/>
        <Setter Property="Height"          Value="34"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#25FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#40000000"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Botón cerrar ventana (hover rojo) ─────────────────── -->
    <Style x:Key="BtnVentanaCerrar" TargetType="Button" BasedOn="{StaticResource BtnVentana}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#C0392B"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#96281B"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Botón _ y ⊞ dentro de un tab (hover gris) ───────── -->
    <Style x:Key="BtnTabCtrl" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground"      Value="#555555"/>
        <Setter Property="Width"           Value="18"/>
        <Setter Property="Height"          Value="18"/>
        <Setter Property="Padding"         Value="0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="9">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#DDDDDD"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#BBBBBB"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Botón X dentro de un tab ─────────────────────────── -->
    <Style x:Key="BtnTabCerrar" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground"      Value="#007864"/>
        <Setter Property="Width"           Value="18"/>
        <Setter Property="Height"          Value="18"/>
        <Setter Property="Padding"         Value="0"/>
        <Setter Property="Margin"          Value="4,0,0,0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            CornerRadius="9">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#C0392B"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Botón principal del sidebar con flyout ───────────── -->
    <Style x:Key="BtnMenuPrincipal" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="#333333"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="16,0"/>
        <Setter Property="Height"          Value="48"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="FontFamily"      Value="Segoe UI Semibold"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderThickness="3,0,0,0"
                            BorderBrush="Transparent"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#E0E0E0"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="#1ABC9C"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#D4D4D4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Botón ítem dentro del flyout ──────────────────────── -->
    <Style x:Key="BtnFlyoutOpcion" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="#333333"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="12,9"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#EEF8F6"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#D8EFEA"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Botón de menú lateral ─────────────────────────────── -->
    <Style x:Key="BtnMenu" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="20,14"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}">
                        <Grid>
                            <Border x:Name="overlay" Background="Transparent"/>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="overlay" Property="Background" Value="#20FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="overlay" Property="Background" Value="#35000000"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Boton Menu oval (barra inferior) -->
    <Style x:Key="BtnMenuPill" TargetType="Button">
        <Setter Property="Background"      Value="White"/>
        <Setter Property="Foreground"      Value="#1ABC9C"/>
        <Setter Property="BorderBrush"     Value="#1ABC9C"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="19"
                            Padding="14,0">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#E8FAF7"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#D0F0EA"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── ScrollBar moderna y delgada ─────────────────────────────────── -->
    <Style x:Key="ScrollThumbStyle" TargetType="Thumb">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="thumb" CornerRadius="5" Background="#BDBDBD" Margin="1"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="thumb" Property="Background" Value="#1ABC9C"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="thumb" Property="Background" Value="#007864"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Style.Triggers>
            <!-- Vertical -->
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Width"  Value="10"/>
                <Setter Property="MinWidth" Value="10"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid>
                                <Border CornerRadius="5" Background="#E0E0E0" Width="10" HorizontalAlignment="Center"/>
                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ScrollThumbStyle}" Width="10"/>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
            <!-- Horizontal -->
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height"    Value="10"/>
                <Setter Property="MinHeight" Value="10"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid>
                                <Border CornerRadius="5" Background="#E0E0E0" Height="10" VerticalAlignment="Center"/>
                                <Track x:Name="PART_Track">
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ScrollThumbStyle}" Height="10"/>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
