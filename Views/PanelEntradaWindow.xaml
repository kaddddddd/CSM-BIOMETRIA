<Window x:Class="CSMBiometricoWPF.Views.PanelEntradaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panel de Ingresos — CSM Biométrico"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="White"
        KeyDown="Window_KeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>  <!-- Encabezado -->
            <RowDefinition Height="*"/>   <!-- Contenido -->
            <RowDefinition Height="32"/>  <!-- Pie -->
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════
             ENCABEZADO  (verde institucional)
             ════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#007864">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="240"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + Nombre institución -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="28,0">
                    <Border Width="50" Height="50" CornerRadius="6"
                            Background="#005A4A" Margin="0,0,16,0">
                        <Image x:Name="imgLogo" Stretch="Uniform" Margin="6"/>
                    </Border>

                    <Rectangle Width="1" Margin="0,10" Fill="#FFFFFF" Opacity="0.3"/>

                    <StackPanel VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock x:Name="lblInstitucion"
                                   FontFamily="Segoe UI Black" FontSize="22"
                                   Foreground="White"/>
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <Ellipse Width="6" Height="6" Fill="#A5D6A7"
                                     VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <TextBlock Text="CONTROL DE ACCESO  ·  REGISTRO DE INGRESOS"
                                       FontFamily="Segoe UI" FontSize="10"
                                       Foreground="#B2DFDB"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Fecha + Reloj -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                            HorizontalAlignment="Center" Margin="0,0,28,0">
                    <TextBlock x:Name="lblHora"
                               FontFamily="Consolas" FontSize="34"
                               Foreground="White" TextAlignment="Center"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="lblFecha"
                               FontFamily="Segoe UI" FontSize="10"
                               Foreground="#B2DFDB" TextAlignment="Center"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════
             CONTENIDO PRINCIPAL
             ════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Barra lateral de estadísticas ──────────────── -->
            <Border Grid.Column="0"
                    Background="#F5F7FA"
                    BorderThickness="0,0,1,0" BorderBrush="#E0E0E0">
                <DockPanel>

                    <!-- Botones en la parte inferior -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,16">

                        <!-- Indicador de conexión -->
                        <Border x:Name="pnlConexion" CornerRadius="8"
                                Background="White" BorderBrush="#E0E0E0"
                                BorderThickness="1" Padding="14,8" Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="dotConexion"
                                         Width="8" Height="8"
                                         Fill="#4CAF50"
                                         VerticalAlignment="Center"
                                         Margin="0,0,10,0"/>
                                <TextBlock x:Name="lblConexion"
                                           Text="EN LÍNEA"
                                           FontFamily="Segoe UI SemiBold" FontSize="11"
                                           Foreground="#388E3C"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Botón actualizar -->
                        <Button Height="38" Margin="0,0,0,8"
                                Click="BtnRefrescar_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="brd" CornerRadius="8"
                                            Background="White"
                                            BorderBrush="#007864" BorderThickness="1.5">
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="↻" FontSize="14" Foreground="#007864"
                                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Actualizar ahora"
                                                       FontFamily="Segoe UI SemiBold" FontSize="12"
                                                       Foreground="#007864" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="brd" Property="Background" Value="#E8F5E9"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="brd" Property="Background" Value="#C8E6C9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Botón cerrar -->
                        <Button Height="38" Click="BtnCerrar_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="brd" CornerRadius="8"
                                            Background="White"
                                            BorderBrush="#BDBDBD" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="✕" FontSize="12" Foreground="#757575"
                                                       Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Cerrar Panel"
                                                       FontFamily="Segoe UI SemiBold" FontSize="12"
                                                       Foreground="#616161" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="brd" Property="Background" Value="#FAFAFA"/>
                                            <Setter TargetName="brd" Property="BorderBrush" Value="#9E9E9E"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <!-- Estadísticas (parte superior) -->
                    <StackPanel Margin="16,20,16,0">

                        <TextBlock Text="RESUMEN DEL DÍA"
                                   FontFamily="Segoe UI SemiBold" FontSize="9"
                                   Foreground="#007864" Margin="4,0,0,14"/>

                        <!-- Tarjeta TOTAL INGRESOS -->
                        <Border CornerRadius="10" Margin="0,0,0,10"
                                Background="White"
                                BorderBrush="#E0E0E0" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1"
                                                  Color="#000000" Opacity="0.06"/>
                            </Border.Effect>
                            <Grid Margin="16,14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Text="TOTAL INGRESOS HOY"
                                           FontFamily="Segoe UI" FontSize="9"
                                           Foreground="#9E9E9E"/>
                                <Grid Grid.Row="1" Margin="0,4,0,0">
                                    <TextBlock x:Name="lblStatPresentes" Text="—"
                                               FontFamily="Segoe UI Black" FontSize="52"
                                               Foreground="#1565C0"
                                               HorizontalAlignment="Left"/>
                                    <Border Background="#E3F2FD" CornerRadius="16"
                                            Padding="10,3"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom">
                                        <TextBlock Text="estudiantes"
                                                   FontFamily="Segoe UI" FontSize="9"
                                                   Foreground="#1565C0"/>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Tarjeta A TIEMPO -->
                        <Border CornerRadius="10" Margin="0,0,0,8"
                                Background="White"
                                BorderBrush="#E0E0E0" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1"
                                                  Color="#000000" Opacity="0.06"/>
                            </Border.Effect>
                            <Grid Margin="14,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontFamily="Segoe UI SemiBold" FontSize="12"
                                               Foreground="#2E7D32">
                                        <Run Text="✓ " FontSize="10"/>
                                        <Run Text="A TIEMPO"/>
                                    </TextBlock>
                                    <TextBlock Text="Llegada puntual"
                                               FontFamily="Segoe UI" FontSize="9"
                                               Foreground="#81C784" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock x:Name="lblStatATiempo" Text="0" Grid.Column="1"
                                           FontFamily="Segoe UI Black" FontSize="38"
                                           Foreground="#2E7D32" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Tarjeta TARDANZAS -->
                        <Border CornerRadius="10" Margin="0,0,0,16"
                                Background="White"
                                BorderBrush="#E0E0E0" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1"
                                                  Color="#000000" Opacity="0.06"/>
                            </Border.Effect>
                            <Grid Margin="14,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontFamily="Segoe UI SemiBold" FontSize="12"
                                               Foreground="#E65100">
                                        <Run Text="⚠ " FontSize="10"/>
                                        <Run Text="TARDANZAS"/>
                                    </TextBlock>
                                    <TextBlock Text="Llegada tardía"
                                               FontFamily="Segoe UI" FontSize="9"
                                               Foreground="#FFB74D" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock x:Name="lblStatTardanzas" Text="0" Grid.Column="1"
                                           FontFamily="Segoe UI Black" FontSize="38"
                                           Foreground="#E65100" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Separador -->
                        <Rectangle Height="1" Margin="4,0,4,16" Fill="#E0E0E0"/>

                        <!-- ── Lector biométrico ─────────────────────── -->
                        <TextBlock Text="LECTOR BIOMÉTRICO"
                                   FontFamily="Segoe UI SemiBold" FontSize="9"
                                   Foreground="#007864" Margin="4,0,0,10"/>

                        <Border CornerRadius="10" Background="White"
                                BorderBrush="#E0E0E0" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1"
                                                  Color="#000000" Opacity="0.06"/>
                            </Border.Effect>
                            <StackPanel Margin="14,14">

                                <!-- Estado del lector -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Ellipse x:Name="dotLector" Width="8" Height="8"
                                             Fill="#9E9E9E" VerticalAlignment="Center"
                                             Margin="0,0,8,0"/>
                                    <TextBlock x:Name="lblEstadoLector"
                                               Text="Inicializando..."
                                               FontFamily="Segoe UI" FontSize="11"
                                               Foreground="#757575"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Imagen de huella con animación de pulso -->
                                <Border Width="96" Height="96" CornerRadius="10"
                                        Background="#F5F7FA" BorderBrush="#E0E0E0"
                                        BorderThickness="1"
                                        HorizontalAlignment="Center" Margin="0,0,0,12">
                                    <Grid>
                                        <Ellipse x:Name="elpPulso"
                                                 Width="72" Height="72"
                                                 Fill="#007864" Opacity="0.15"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                                        <Image x:Name="imgHuellaPanel"
                                               Stretch="Uniform" Margin="10"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Grid>
                                </Border>

                                <!-- Instrucción -->
                                <TextBlock x:Name="lblInstruccionPanel"
                                           Text="Coloque su dedo en el sensor"
                                           FontFamily="Segoe UI SemiBold" FontSize="11"
                                           Foreground="#546E7A"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ── Área principal: lista de ingresos ───────────── -->
            <Grid Grid.Column="1" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>  <!-- Cabecera columnas -->
                    <RowDefinition Height="*"/>   <!-- Filas -->
                </Grid.RowDefinitions>

                <!-- Resultado de identificación (overlay temporal, aparece encima de la lista) -->
                <Border x:Name="pnlResultadoLector"
                        Grid.RowSpan="2" VerticalAlignment="Top"
                        Visibility="Collapsed" Panel.ZIndex="10"
                        Padding="24,18">
                    <Border.Background>
                        <SolidColorBrush x:Name="brushResultado" Color="#1B5E20"/>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="lblNombreResult" Text=""
                                       FontFamily="Segoe UI Black" FontSize="22"
                                       Foreground="White"/>
                            <TextBlock x:Name="lblDetalleResult" Text=""
                                       FontFamily="Segoe UI" FontSize="11"
                                       Foreground="#B2DFDB" Margin="0,3,0,0"/>
                        </StackPanel>

                        <Border Grid.Column="1" x:Name="brdEstadoResult"
                                CornerRadius="24" Padding="22,10"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="lblEstadoResult" Text=""
                                       FontFamily="Segoe UI Black" FontSize="15"
                                       Foreground="White" TextAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Cabecera de columnas -->
                <Border Grid.Row="0"
                        Background="#F5F7FA"
                        BorderThickness="0,0,0,1" BorderBrush="#E0E0E0">
                    <Grid Margin="24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="84"/>
                            <ColumnDefinition Width="48"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="HORA" Grid.Column="0"
                                   FontFamily="Segoe UI SemiBold" FontSize="9"
                                   Foreground="#78909C" VerticalAlignment="Center"/>
                        <TextBlock Text="ESTUDIANTE" Grid.Column="2"
                                   FontFamily="Segoe UI SemiBold" FontSize="9"
                                   Foreground="#78909C" VerticalAlignment="Center"/>
                        <TextBlock Text="GRADO · GRUPO" Grid.Column="3"
                                   FontFamily="Segoe UI SemiBold" FontSize="9"
                                   Foreground="#78909C" VerticalAlignment="Center"/>
                        <TextBlock Text="ESTADO" Grid.Column="4"
                                   FontFamily="Segoe UI SemiBold" FontSize="9"
                                   Foreground="#78909C"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Lista de registros -->
                <ListView x:Name="listIngresos" Grid.Row="1"
                          Background="Transparent"
                          BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          AlternationCount="2">

                    <ListView.Resources>
                        <Style TargetType="ScrollBar">
                            <Setter Property="Width" Value="5"/>
                            <Setter Property="Background" Value="#F5F5F5"/>
                        </Style>
                    </ListView.Resources>

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="rowBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderThickness="0,0,0,1"
                                                BorderBrush="#F0F0F0">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                                <Setter TargetName="rowBorder"
                                                        Property="Background" Value="#FAFAFA"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="rowBorder"
                                                        Property="Background" Value="#F1F8F6"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="68" Margin="24,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="84"/>   <!-- Hora -->
                                    <ColumnDefinition Width="48"/>   <!-- Avatar -->
                                    <ColumnDefinition Width="*"/>    <!-- Nombre/ID -->
                                    <ColumnDefinition Width="200"/>  <!-- Grado·Grupo -->
                                    <ColumnDefinition Width="150"/>  <!-- Estado -->
                                </Grid.ColumnDefinitions>

                                <!-- Hora -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Hora}"
                                               FontFamily="Consolas" FontSize="17"
                                               FontWeight="Bold"
                                               Foreground="#37474F"/>
                                    <Border x:Name="badgeNuevo"
                                            Background="#E8F5E9" CornerRadius="3"
                                            Padding="5,1" HorizontalAlignment="Left"
                                            Visibility="{Binding BadgeNuevoVisibility}">
                                        <TextBlock Text="NUEVO"
                                                   FontFamily="Segoe UI SemiBold"
                                                   FontSize="8" Foreground="#2E7D32"/>
                                    </Border>
                                </StackPanel>

                                <!-- Avatar circular con iniciales -->
                                <Border Grid.Column="1"
                                        Width="38" Height="38"
                                        CornerRadius="19"
                                        Background="{Binding AvatarFondo}"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Iniciales}"
                                               FontFamily="Segoe UI SemiBold"
                                               FontSize="13" Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- Nombre + Identificación -->
                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Margin="0,0,16,0">
                                    <TextBlock Text="{Binding Nombre}"
                                               FontFamily="Segoe UI SemiBold"
                                               FontSize="14"
                                               Foreground="#263238"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Identificacion}"
                                               FontFamily="Segoe UI" FontSize="11"
                                               Foreground="#78909C"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- Grado · Grupo -->
                                <TextBlock Grid.Column="3"
                                           Text="{Binding GradoGrupo}"
                                           FontFamily="Segoe UI" FontSize="13"
                                           Foreground="#546E7A"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,16,0"/>

                                <!-- Pill de estado -->
                                <Border Grid.Column="4"
                                        Background="{Binding EstadoFondo}"
                                        BorderBrush="{Binding EstadoBorde}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="12,5"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        MinWidth="120">
                                    <TextBlock Text="{Binding EstadoTexto}"
                                               FontFamily="Segoe UI SemiBold"
                                               FontSize="11"
                                               Foreground="{Binding EstadoColor}"
                                               TextAlignment="Center"/>
                                </Border>

                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>

                </ListView>

                <!-- Mensaje cuando no hay registros -->
                <StackPanel x:Name="pnlSinDatos"
                            Grid.Row="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="📋"
                               FontSize="64"
                               HorizontalAlignment="Center" Opacity="0.2"/>
                    <TextBlock Text="Sin ingresos registrados hoy"
                               FontFamily="Segoe UI Light" FontSize="20"
                               Foreground="#B0BEC5"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0"/>
                    <TextBlock Text="Los registros aparecerán aquí en tiempo real"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="#CFD8DC"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ════════════════════════════════════════
             PIE DE PANTALLA
             ════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#F5F7FA"
                BorderThickness="0,1,0,0" BorderBrush="#E0E0E0">
            <Grid Margin="28,0">
                <TextBlock x:Name="lblUltimaActualizacion"
                           FontFamily="Segoe UI" FontSize="10"
                           Foreground="#9E9E9E"
                           VerticalAlignment="Center"/>
                <TextBlock Text="ESC — cerrar panel  ·  F5 — actualizar"
                           FontFamily="Segoe UI" FontSize="10"
                           Foreground="#BDBDBD"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════
             OVERLAY: SELECTOR DE INSTITUCIÓN
             ════════════════════════════════════════ -->
        <Grid x:Name="pnlSelectorInstitucion"
              Grid.RowSpan="3"
              Visibility="Collapsed">
            <Grid.Background>
                <SolidColorBrush Color="White" Opacity="0.92"/>
            </Grid.Background>

            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="460"
                    CornerRadius="14"
                    Background="White"
                    BorderBrush="#E0E0E0" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="0"
                                      Color="#000000" Opacity="0.12"/>
                </Border.Effect>

                <StackPanel Margin="36,32">

                    <!-- Logo + título -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Border Width="44" Height="44" CornerRadius="8"
                                Background="#007864" Margin="0,0,14,0">
                            <Image x:Name="imgLogoSelector" Stretch="Uniform" Margin="6"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="CSM BIOMÉTRICO"
                                       FontFamily="Segoe UI Black" FontSize="14"
                                       Foreground="#263238"/>
                            <TextBlock Text="Panel de Control de Acceso"
                                       FontFamily="Segoe UI" FontSize="10"
                                       Foreground="#007864"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Separador -->
                    <Rectangle Height="1" Margin="0,0,0,24" Fill="#E0E0E0"/>

                    <TextBlock Text="Seleccionar institución"
                               FontFamily="Segoe UI SemiBold" FontSize="13"
                               Foreground="#546E7A" Margin="0,0,0,8"/>

                    <!-- ComboBox de instituciones -->
                    <ComboBox x:Name="cmbInstitucionSelector"
                              Height="42"
                              FontFamily="Segoe UI" FontSize="14"
                              Foreground="#263238"
                              Margin="0,0,0,20"/>

                    <!-- Botón abrir -->
                    <Button Content="Abrir Panel de Ingresos →"
                            Height="44"
                            FontFamily="Segoe UI SemiBold" FontSize="14"
                            Cursor="Hand"
                            Click="BtnAbrirPanel_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="brd" CornerRadius="10"
                                        Background="#007864">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      TextElement.Foreground="White"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="brd" Property="Background" Value="#009678"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="brd" Property="Background" Value="#005A4A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <TextBlock Text="También puede presionar Enter para confirmar"
                               FontFamily="Segoe UI" FontSize="10"
                               Foreground="#BDBDBD"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>
