<Page x:Class="CSMBiometricoWPF.Views.Pages.ReportesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F7FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>  <!-- Header -->
            <RowDefinition Height="55"/>  <!-- Filtros fila 1: tipo, fechas, acciones -->
            <RowDefinition Height="50"/>  <!-- Filtros fila 2: sede, grado, estado, estudiante -->
            <RowDefinition Height="*"/>   <!-- Grid -->
            <RowDefinition Height="35"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource PanelHeader}">
            <TextBlock Text="Reportes de Asistencia" Style="{StaticResource LblTituloHeader}"/>
        </Border>

        <!-- Filtros fila 1: tipo, fechas y botones -->
        <Border Grid.Row="1" Background="#007864" Padding="12,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Tipo:" Foreground="White" VerticalAlignment="Center"
                           FontSize="13" Margin="0,0,8,0"/>
                <ComboBox x:Name="cmbTipoReporte" Width="170" Height="32"
                          Style="{StaticResource CmbBase}" Margin="0,0,20,0"
                          SelectionChanged="TipoReporte_Changed"/>

                <TextBlock Text="Desde:" Foreground="White" VerticalAlignment="Center"
                           FontSize="13" Margin="0,0,8,0"/>
                <DatePicker x:Name="dpDesde" Width="130" Height="32" Margin="0,0,16,0"/>

                <TextBlock Text="Hasta:" Foreground="White" VerticalAlignment="Center"
                           FontSize="13" Margin="0,0,8,0"/>
                <DatePicker x:Name="dpHasta" Width="130" Height="32" Margin="0,0,20,0"/>

                <Button Content="🔍  Generar" Style="{StaticResource BtnPrimario}"
                        Background="#009678" Width="120" Height="32" Margin="0,0,8,0"
                        Click="BtnGenerar_Click"/>
                <Button Content="📤  Exportar" Style="{StaticResource BtnNaranja}"
                        Width="110" Height="32"
                        Click="BtnExportar_Click"/>
            </StackPanel>
        </Border>

        <!-- Filtros fila 2: sede, grado, estado, estudiante -->
        <Border Grid.Row="2" Background="#ECEFF1" Padding="12,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Sede:" VerticalAlignment="Center" FontSize="12" Margin="0,0,8,0"/>
                <ComboBox x:Name="cmbSede" Width="150" Height="28"
                          Style="{StaticResource CmbBase}" Margin="0,0,16,0"/>

                <TextBlock Text="Grado:" VerticalAlignment="Center" FontSize="12" Margin="0,0,8,0"/>
                <ComboBox x:Name="cmbGrado" Width="130" Height="28"
                          Style="{StaticResource CmbBase}" Margin="0,0,16,0"/>

                <TextBlock Text="Estado:" VerticalAlignment="Center" FontSize="12" Margin="0,0,8,0"/>
                <ComboBox x:Name="cmbEstado" Width="120" Height="28"
                          Style="{StaticResource CmbBase}" Margin="0,0,16,0"/>

                <TextBlock Text="Estudiante:" VerticalAlignment="Center" FontSize="12" Margin="0,0,8,0"/>
                <TextBox x:Name="txtEstudiante" Width="180" Height="28"
                         Style="{StaticResource TxtBase}"
                         TextChanged="TxtEstudiante_TextChanged"/>
            </StackPanel>
        </Border>

        <!-- Grid resultado -->
        <DataGrid x:Name="grid" Grid.Row="3"
                  Style="{StaticResource GridBase}"
                  ColumnHeaderStyle="{StaticResource GridHeaderStyle}">
        </DataGrid>

        <!-- Status bar -->
        <Border Grid.Row="4" Background="#ECEFF1" Padding="16,0">
            <TextBlock x:Name="lblTotal" Text="Seleccione un tipo de reporte y presione Generar"
                       VerticalAlignment="Center" FontSize="12"
                       HorizontalAlignment="Right"/>
        </Border>
    </Grid>
</Page>
