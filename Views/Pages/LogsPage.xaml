<Page x:Class="CSMBiometricoWPF.Views.Pages.LogsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F7FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>  <!-- Banner -->
            <RowDefinition Height="50"/>  <!-- Toolbar -->
            <RowDefinition Height="50"/>  <!-- Filtros -->
            <RowDefinition Height="*"/>   <!-- Grid -->
            <RowDefinition Height="35"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Banner -->
        <Border Grid.Row="0" Style="{StaticResource PanelHeader}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                           Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="Registros del Sistema" Style="{StaticResource LblTituloHeader}"/>
            </StackPanel>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarAcciones}">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource BtnSecundario}"
                        Width="120" Height="35" Margin="0,0,8,0"
                        Click="BtnRefrescar_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Refrescar" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource BtnNaranja}"
                        Width="140" Height="35"
                        Click="BtnLimpiar_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Limpiar filtros" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Filtros -->
        <Border Grid.Row="2" Style="{StaticResource BarraFiltros}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Nivel:" Style="{StaticResource LblFiltro}" Margin="0,0,8,0"/>
                <ComboBox x:Name="cmbNivel" Width="120" Height="30"
                          Style="{StaticResource CmbBase}" Margin="0,0,16,0"
                          SelectionChanged="Filtro_Changed"/>

                <TextBlock Text="Tipo evento:" Style="{StaticResource LblFiltro}" Margin="0,0,8,0"/>
                <ComboBox x:Name="cmbTipo" Width="170" Height="30"
                          Style="{StaticResource CmbBase}" Margin="0,0,16,0"
                          SelectionChanged="Filtro_Changed"/>

                <TextBlock Text="Buscar:" Style="{StaticResource LblFiltro}" Margin="0,0,8,0"/>
                <TextBox x:Name="txtBuscar" Width="200" Height="30"
                         Style="{StaticResource TxtBase}"
                         TextChanged="TxtBuscar_Changed"/>
            </StackPanel>
        </Border>

        <!-- Grid de logs -->
        <DataGrid x:Name="grid" Grid.Row="3"
                  Style="{StaticResource GridBase}"
                  ColumnHeaderStyle="{StaticResource GridHeaderStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Fecha"       Binding="{Binding FechaEvento, StringFormat='dd/MM/yyyy HH:mm:ss'}" Width="160"/>
                <DataGridTextColumn Header="Nivel"       Binding="{Binding Nivel}"       Width="100"/>
                <DataGridTextColumn Header="Tipo evento" Binding="{Binding TipoEvento}"  Width="150"/>
                <DataGridTextColumn Header="Usuario"     Binding="{Binding NombreUsuario}" Width="160"/>
                <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"/>
            </DataGrid.Columns>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <!-- Color por nivel de severidad -->
                        <DataTrigger Binding="{Binding Nivel}" Value="ERROR">
                            <Setter Property="Background" Value="#FFEBEE"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Nivel}" Value="CRITICO">
                            <Setter Property="Background" Value="#FFCDD2"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Nivel}" Value="ADVERTENCIA">
                            <Setter Property="Background" Value="#FFF8E1"/>
                        </DataTrigger>
                        <!-- Selección (mayor prioridad al ir después) -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#E8F5F2"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#D0EFEA"/>
                            <Setter Property="Foreground" Value="#003828"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <!-- Status bar -->
        <Border Grid.Row="4" Style="{StaticResource StatusBar}">
            <TextBlock x:Name="lblTotal" Text="Mostrando 0 registros"
                       VerticalAlignment="Center" FontSize="12"
                       HorizontalAlignment="Right"/>
        </Border>
    </Grid>
</Page>
