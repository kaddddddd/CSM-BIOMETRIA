<Page x:Class="CSMBiometricoWPF.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F7FA">

    <Page.Resources>
        <!-- Color del texto según estado de ingreso -->
        <Style x:Key="CeldaEstado" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding EsTarde}" Value="True">
                    <Setter Property="Foreground" Value="#E65100"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding EsAusente}" Value="True">
                    <Setter Property="Foreground" Value="#B71C1C"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CeldaHora" TargetType="TextBlock">
            <Style.Triggers>
                <DataTrigger Binding="{Binding EsTarde}" Value="True">
                    <Setter Property="Foreground" Value="#E65100"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>   <!-- Header -->
            <RowDefinition Height="58"/>   <!-- Filtros -->
            <RowDefinition Height="142"/>  <!-- Cards -->
            <RowDefinition Height="44"/>   <!-- Label grid -->
            <RowDefinition Height="*"/>    <!-- Grid de registros -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource PanelHeader}">
            <Grid>
                <TextBlock Text="Dashboard  —  Estadísticas de Asistencia"
                           Style="{StaticResource LblTituloHeader}"/>
                <TextBlock x:Name="lblFechaCabecera"
                           Style="{StaticResource LblSubtituloHeader}"
                           HorizontalAlignment="Right" Margin="0,0,20,0"/>
            </Grid>
        </Border>

        <!-- Barra de filtros -->
        <Border Grid.Row="1" Background="White" Padding="16,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.08" Direction="270"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Período:" Style="{StaticResource LblFiltro}" Margin="0,0,6,0"/>
                <ComboBox x:Name="cmbPeriodo" Width="130" Height="32" Margin="0,0,10,0"
                          Style="{StaticResource CmbBase}"
                          SelectionChanged="CmbPeriodo_SelectionChanged"/>
                <!-- Visible sólo cuando el período es "Personalizado" -->
                <StackPanel x:Name="pnlFechasCustom" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="Desde:" Style="{StaticResource LblFiltro}" Margin="0,0,4,0"/>
                    <DatePicker x:Name="dpDesde" Width="115" Height="32" Margin="0,0,10,0"
                                VerticalContentAlignment="Center"
                                SelectedDateChanged="DpFecha_SelectedDateChanged"/>
                    <TextBlock Text="Hasta:" Style="{StaticResource LblFiltro}" Margin="0,0,4,0"/>
                    <DatePicker x:Name="dpHasta" Width="115" Height="32" Margin="0,0,10,0"
                                VerticalContentAlignment="Center"
                                SelectedDateChanged="DpFecha_SelectedDateChanged"/>
                </StackPanel>
                <!-- Separador vertical -->
                <Border Width="1" Background="#E0E0E0" Margin="4,8,16,8"/>
                <TextBlock Text="Filtrar por:" Style="{StaticResource LblFiltro}" Margin="0,0,10,0"/>
                <ComboBox x:Name="cmbInstitucion" Width="210" Height="32"
                          Style="{StaticResource CmbBase}" Margin="0,0,8,0" SelectionChanged="cmbInstitucion_SelectionChanged"/>
                <ComboBox x:Name="cmbSede"        Width="190" Height="32"
                          DisplayMemberPath="NombreSede"
                          Style="{StaticResource CmbBase}" Margin="0,0,8,0"
                          SelectionChanged="CmbFiltro_SelectionChanged"/>
                <ComboBox x:Name="cmbGrado"       Width="165" Height="32"
                          Style="{StaticResource CmbBase}" Margin="0,0,8,0"
                          SelectionChanged="CmbFiltro_SelectionChanged"/>
                <ComboBox x:Name="cmbGrupo"       Width="160" Height="32"
                          Style="{StaticResource CmbBase}" Margin="0,0,10,0"
                          SelectionChanged="CmbFiltro_SelectionChanged"/>
                <Button Content="🗑  Limpiar" Style="{StaticResource BtnSecundario}"
                        Height="32" Padding="10,0" Width="90" Click="BtnLimpiar_Click"/>
            </StackPanel>
        </Border>

        <!-- Fila de cards -->
        <Border Grid.Row="2" Background="#F0F4F3">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled" Padding="16,14">
                <StackPanel x:Name="pnlCards" Orientation="Horizontal"/>
            </ScrollViewer>
        </Border>

        <!-- Header del grid -->
        <Border Grid.Row="3" Background="White" Padding="20,0"
                BorderThickness="0,0,0,1" BorderBrush="#E8ECED">
            <TextBlock x:Name="lblGridTitulo"
                       FontFamily="Segoe UI SemiBold" FontSize="13"
                       Foreground="#007864" VerticalAlignment="Center"/>
        </Border>

        <!-- Grid de registros por estudiante -->
        <DataGrid x:Name="grid" Grid.Row="4"
                  Style="{StaticResource GridBase}"
                  ColumnHeaderStyle="{StaticResource GridHeaderStyle}">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="DetailsVisibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Expandido}" Value="True">
                            <Setter Property="DetailsVisibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <!-- Detalle expandible: faltas del estudiante -->
            <DataGrid.RowDetailsTemplate>
                <DataTemplate>
                    <Border Background="#FFFDE7" Padding="50,8,16,10"
                            BorderThickness="0,0,0,1" BorderBrush="#FFE082">
                        <StackPanel>
                            <!-- Encabezado con conteo -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Inasistencias: " FontSize="11"
                                           FontWeight="SemiBold" Foreground="#555"/>
                                <TextBlock Text="{Binding TotalFaltas}" FontSize="11"
                                           FontWeight="Bold" Foreground="#C62828"/>
                            </StackPanel>

                            <!-- Chips en WrapPanel con scroll vertical limitado -->
                            <ScrollViewer MaxHeight="90" VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding Faltas}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="7,4" Margin="0,0,6,5">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#FFCDD2"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Estado}" Value="Inasistencia">
                                                                <Setter Property="Background" Value="#FFE0B2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DiaSemanaCorto}"
                                                               FontSize="9" Foreground="#888"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding FechaCorta}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Foreground="#B71C1C"
                                                               HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <TextBlock Text="Sin inasistencias en este período"
                                       FontSize="11" Foreground="#888">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TotalFaltas}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>

            <DataGrid.Columns>
                <!-- Botón +/- -->
                <DataGridTemplateColumn Width="38" CanUserResize="False"
                                        CanUserSort="False" CanUserReorder="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Width="26" Height="26" FontSize="14" FontWeight="Bold"
                                    Foreground="#007864" Cursor="Hand" ToolTip="Ver faltas"
                                    Click="BtnExpandir_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Content" Value="＋"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Expandido}" Value="True">
                                                <Setter Property="Content" Value="－"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Width="24" Height="24" CornerRadius="4"
                                                Background="Transparent" BorderBrush="#B2DFDB" BorderThickness="1">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#E0F2EE"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Estudiante"     Binding="{Binding NombreEstudiante}" Width="*"/>
                <DataGridTextColumn Header="Identificación" Binding="{Binding Identificacion}"   Width="120"/>
                <DataGridTextColumn Header="Grado"          Binding="{Binding NombreGrado}"      Width="90"/>
                <DataGridTextColumn Header="Grupo"          Binding="{Binding NombreGrupo}"      Width="70"/>
                <DataGridTextColumn Header="Sede"           Binding="{Binding NombreSede}"       Width="140"/>
                <DataGridTextColumn Header="Faltas"         Binding="{Binding TotalFaltas}"      Width="70"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
