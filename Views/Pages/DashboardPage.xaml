<Page x:Class="CSMBiometricoWPF.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F7FA">

    <Page.Resources>
        <!-- Color del texto según estado de ingreso -->
        <Style x:Key="CeldaEstado" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding EsTarde}" Value="True">
                    <Setter Property="Foreground" Value="#E65100"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding EsAusente}" Value="True">
                    <Setter Property="Foreground" Value="#B71C1C"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CeldaHora" TargetType="TextBlock">
            <Style.Triggers>
                <DataTrigger Binding="{Binding EsTarde}" Value="True">
                    <Setter Property="Foreground" Value="#E65100"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>   <!-- Header -->
            <RowDefinition Height="50"/>   <!-- Filtros -->
            <RowDefinition Height="130"/>  <!-- Cards -->
            <RowDefinition Height="36"/>   <!-- Label grid -->
            <RowDefinition Height="*"/>    <!-- Grid de registros -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource PanelHeader}">
            <Grid>
                <TextBlock Text="Dashboard  —  Estadísticas de Asistencia"
                           Style="{StaticResource LblTituloHeader}"/>
                <TextBlock x:Name="lblFechaCabecera"
                           Style="{StaticResource LblSubtituloHeader}"
                           HorizontalAlignment="Right" Margin="0,0,20,0"/>
            </Grid>
        </Border>

        <!-- Barra de filtros -->
        <Border Grid.Row="1" Background="White" Padding="16,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.08" Direction="270"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Período:" VerticalAlignment="Center"
                           FontSize="12" Foreground="#666" Margin="0,0,6,0"/>
                <ComboBox x:Name="cmbPeriodo" Width="120" Height="28" Margin="0,0,8,0"
                          Style="{StaticResource CmbBase}"
                          SelectionChanged="CmbPeriodo_SelectionChanged"/>
                <!-- Visible sólo cuando el período es "Personalizado" -->
                <StackPanel x:Name="pnlFechasCustom" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="Desde:" VerticalAlignment="Center"
                               FontSize="12" Foreground="#666" Margin="0,0,4,0"/>
                    <DatePicker x:Name="dpDesde" Width="115" Height="28" Margin="0,0,8,0"
                                VerticalContentAlignment="Center"
                                SelectedDateChanged="DpFecha_SelectedDateChanged"/>
                    <TextBlock Text="Hasta:" VerticalAlignment="Center"
                               FontSize="12" Foreground="#666" Margin="0,0,4,0"/>
                    <DatePicker x:Name="dpHasta" Width="115" Height="28" Margin="0,0,8,0"
                                VerticalContentAlignment="Center"
                                SelectedDateChanged="DpFecha_SelectedDateChanged"/>
                </StackPanel>
                <TextBlock Text="|" VerticalAlignment="Center"
                           Foreground="#DDD" FontSize="18" Margin="0,0,14,0"/>
                <TextBlock Text="Filtrar por:" VerticalAlignment="Center"
                           FontSize="12" Foreground="#666" Margin="0,0,12,0"/>
                <ComboBox x:Name="cmbInstitucion" Width="180" Height="28"
                          Style="{StaticResource CmbBase}" Margin="0,0,10,0"/>
                <ComboBox x:Name="cmbSede"        Width="180" Height="28"
                          Style="{StaticResource CmbBase}" Margin="0,0,10,0"
                          SelectionChanged="CmbFiltro_SelectionChanged"/>
                <ComboBox x:Name="cmbGrado"       Width="140" Height="28"
                          Style="{StaticResource CmbBase}" Margin="0,0,10,0"
                          SelectionChanged="CmbFiltro_SelectionChanged"/>
                <ComboBox x:Name="cmbGrupo"       Width="120" Height="28"
                          Style="{StaticResource CmbBase}" Margin="0,0,10,0"
                          SelectionChanged="CmbFiltro_SelectionChanged"/>
                <Button Content="Limpiar" Style="{StaticResource BtnSecundario}"
                        Height="28" Width="72" Click="BtnLimpiar_Click"/>
            </StackPanel>
        </Border>

        <!-- Fila de cards -->
        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled" Padding="16,12">
            <StackPanel x:Name="pnlCards" Orientation="Horizontal"/>
        </ScrollViewer>

        <!-- Header del grid -->
        <Border Grid.Row="3" Background="White" Padding="16,0">
            <TextBlock x:Name="lblGridTitulo"
                       FontFamily="Segoe UI SemiBold" FontSize="13"
                       Foreground="#007864" VerticalAlignment="Center"/>
        </Border>

        <!-- Grid de registros -->
        <DataGrid x:Name="grid" Grid.Row="4"
                  Style="{StaticResource GridBase}"
                  ColumnHeaderStyle="{StaticResource GridHeaderStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Estudiante"     Binding="{Binding NombreEstudiante}" Width="*"/>
                <DataGridTextColumn Header="Identificación" Binding="{Binding Identificacion}"   Width="120"/>
                <DataGridTextColumn Header="Grado"          Binding="{Binding NombreGrado}"      Width="90"/>
                <DataGridTextColumn Header="Grupo"          Binding="{Binding NombreGrupo}"      Width="70"/>
                <DataGridTextColumn Header="Sede"           Binding="{Binding NombreSede}"       Width="140"/>
                <DataGridTextColumn x:Name="colFecha"     Header="Fecha"
                                    Binding="{Binding FechaIngreso, StringFormat=dd/MM/yyyy}"
                                    Width="90" Visibility="Collapsed"/>
                <!-- Hora con color naranja si es tarde -->
                <DataGridTemplateColumn Header="Hora ingreso" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding HoraIngresoStr}"
                                       Style="{StaticResource CeldaHora}"
                                       VerticalAlignment="Center" Padding="4,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!-- Estado con color según resultado -->
                <DataGridTemplateColumn Header="Estado" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding EstadoStr}"
                                       Style="{StaticResource CeldaEstado}"
                                       VerticalAlignment="Center" Padding="4,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
