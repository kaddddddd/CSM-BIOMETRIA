<Page x:Class="CSMBiometricoWPF.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F7FA">

    <Page.Resources>
        <!-- Color del texto según estado de ingreso -->
        <Style x:Key="CeldaEstado" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding EsTarde}" Value="True">
                    <Setter Property="Foreground" Value="#E65100"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding EsAusente}" Value="True">
                    <Setter Property="Foreground" Value="#B71C1C"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CeldaHora" TargetType="TextBlock">
            <Style.Triggers>
                <DataTrigger Binding="{Binding EsTarde}" Value="True">
                    <Setter Property="Foreground" Value="#E65100"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Estilo de pestañas -->
        <Style x:Key="TabItemDash" TargetType="TabItem">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Padding"    Value="18,0"/>
            <Setter Property="Height"     Value="38"/>
            <Setter Property="Foreground" Value="#777"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Background="Transparent"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#007864"/>
                                <Setter Property="Foreground"  Value="#007864"/>
                                <Setter Property="FontWeight"  Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F0F4F3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>   <!-- Header -->
            <RowDefinition Height="58"/>   <!-- Filtros -->
            <RowDefinition Height="Auto"/>  <!-- Cards -->
            <RowDefinition Height="*"/>    <!-- TabControl -->
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────── -->
        <Border Grid.Row="0" Style="{StaticResource PanelHeader}">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                               Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="Dashboard  —  Estadísticas de Asistencia"
                               Style="{StaticResource LblTituloHeader}"/>
                </StackPanel>
                <TextBlock x:Name="lblFechaCabecera"
                           Style="{StaticResource LblSubtituloHeader}"
                           HorizontalAlignment="Right" Margin="0,0,20,0"/>
            </Grid>
        </Border>

        <!-- ── Barra de filtros ─────────────────────────────────────── -->
        <Border Grid.Row="1" Style="{StaticResource BarraFiltros}">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- "Período:" -->
                    <ColumnDefinition Width="130"/>   <!-- cmbPeriodo -->
                    <ColumnDefinition Width="Auto"/>  <!-- fechas custom -->
                    <ColumnDefinition Width="Auto"/>  <!-- separador -->
                    <ColumnDefinition Width="Auto"/>  <!-- "Filtrar por:" -->
                    <ColumnDefinition Width="*"/>     <!-- cmbInstitucion -->
                    <ColumnDefinition Width="*"/>     <!-- cmbSede -->
                    <ColumnDefinition Width="*"/>     <!-- cmbGrado -->
                    <ColumnDefinition Width="*"/>     <!-- cmbGrupo -->
                    <ColumnDefinition Width="Auto"/>  <!-- Btn Limpiar -->
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Período:" Style="{StaticResource LblFiltro}" Margin="0,0,6,0"/>
                <ComboBox Grid.Column="1" x:Name="cmbPeriodo" Height="32" Margin="0,0,10,0"
                          Style="{StaticResource CmbBase}"
                          SelectionChanged="CmbPeriodo_SelectionChanged"/>
                <StackPanel Grid.Column="2" x:Name="pnlFechasCustom" Orientation="Horizontal" Visibility="Collapsed">
                    <TextBlock Text="Desde:" Style="{StaticResource LblFiltro}" Margin="0,0,4,0"/>
                    <DatePicker x:Name="dpDesde" Width="115" Height="32" Margin="0,0,10,0"
                                VerticalContentAlignment="Center"
                                SelectedDateChanged="DpFecha_SelectedDateChanged"/>
                    <TextBlock Text="Hasta:" Style="{StaticResource LblFiltro}" Margin="0,0,4,0"/>
                    <DatePicker x:Name="dpHasta" Width="115" Height="32" Margin="0,0,10,0"
                                VerticalContentAlignment="Center"
                                SelectedDateChanged="DpFecha_SelectedDateChanged"/>
                </StackPanel>
                <Border Grid.Column="3" Width="1" Background="#E0E0E0" Margin="4,8,16,8"/>
                <TextBlock Grid.Column="4" Text="Filtrar por:" Style="{StaticResource LblFiltro}" Margin="0,0,10,0"/>
                <ComboBox Grid.Column="5" x:Name="cmbInstitucion" Height="32"
                          Style="{StaticResource CmbBase}" Margin="0,0,8,0"
                          SelectionChanged="cmbInstitucion_SelectionChanged"/>
                <ComboBox Grid.Column="6" x:Name="cmbSede" Height="32"
                          DisplayMemberPath="NombreSede"
                          Style="{StaticResource CmbBase}" Margin="0,0,8,0"
                          SelectionChanged="CmbFiltro_SelectionChanged"/>
                <ComboBox Grid.Column="7" x:Name="cmbGrado" Height="32"
                          Style="{StaticResource CmbBase}" Margin="0,0,8,0"
                          SelectionChanged="CmbGrado_SelectionChanged"/>
                <ComboBox Grid.Column="8" x:Name="cmbGrupo" Height="32"
                          Style="{StaticResource CmbBase}" Margin="0,0,10,0"
                          SelectionChanged="CmbFiltro_SelectionChanged"/>
                <Button Grid.Column="9" Style="{StaticResource BtnSecundario}"
                        Height="32" Padding="10,0" Width="90" Click="BtnLimpiar_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE75C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Limpiar" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ── Fila de cards ────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#F0F4F3">
            <UniformGrid x:Name="pnlCards" Rows="1" Margin="16,14"/>
        </Border>

        <!-- ── TabControl: Detalle / Gráficas ───────────────────────── -->
        <TabControl Grid.Row="3"
                    Background="White"
                    BorderThickness="0,1,0,0"
                    BorderBrush="#E8ECED"
                    SelectionChanged="TabGraficas_SelectionChanged">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource TabItemDash}"/>
            </TabControl.Resources>

            <!-- ── Tab 1: Detalle (grid existente) ──────────────────── -->
            <TabItem Header="Detalle">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="White" Padding="20,0"
                            BorderThickness="0,0,0,1" BorderBrush="#E8ECED">
                        <TextBlock x:Name="lblGridTitulo"
                                   FontFamily="Segoe UI SemiBold" FontSize="13"
                                   Foreground="#007864" VerticalAlignment="Center"/>
                    </Border>

                    <DataGrid x:Name="grid" Grid.Row="1"
                              Style="{StaticResource GridBase}"
                              ColumnHeaderStyle="{StaticResource GridHeaderStyle}">

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="DetailsVisibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Expandido}" Value="True">
                                        <Setter Property="DetailsVisibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <Border Background="#FFFDE7" Padding="60,10,24,12"
                                        BorderThickness="0,0,0,1" BorderBrush="#FFE082"
                                        HorizontalAlignment="Stretch">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="Inasistencias: " FontSize="11"
                                                       FontWeight="SemiBold" Foreground="#555"/>
                                            <TextBlock Text="{Binding TotalFaltas}" FontSize="11"
                                                       FontWeight="Bold" Foreground="#C62828" Margin="0,0,12,0"/>
                                            <TextBlock FontSize="11" Foreground="#E65100" FontStyle="Italic"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding TieneFaltasFranja}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                                <Run Text="(incluye "/>
                                                <Run Text="{Binding FaltasFranjaCount, Mode=OneWay}"/>
                                                <Run Text=" por franja)"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <ItemsControl ItemsSource="{Binding Faltas}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="6"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="6" Margin="3" Padding="8,5">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#FFCDD2"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding EsFranja}" Value="True">
                                                                        <Setter Property="Background" Value="#FFE0B2"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel Orientation="Vertical">
                                                            <TextBlock Text="{Binding FechaCorta}"
                                                                       FontSize="11" FontWeight="Bold"
                                                                       HorizontalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#B71C1C"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding EsFranja}" Value="True">
                                                                                <Setter Property="Foreground" Value="#BF360C"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding EtiquetaFalta}"
                                                                       FontSize="9" TextWrapping="Wrap"
                                                                       HorizontalAlignment="Center" TextAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#C62828"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding EsFranja}" Value="True">
                                                                                <Setter Property="Foreground" Value="#E65100"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="Sin inasistencias en este período"
                                                   FontSize="11" Foreground="#888">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TotalFaltas}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGrid.RowDetailsTemplate>

                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="38" CanUserResize="False"
                                                    CanUserSort="False" CanUserReorder="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Width="26" Height="26" FontSize="14" FontWeight="Bold"
                                                Foreground="#007864" Cursor="Hand" ToolTip="Ver faltas"
                                                Click="BtnExpandir_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Content" Value="＋"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Expandido}" Value="True">
                                                            <Setter Property="Content" Value="－"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Width="24" Height="24" CornerRadius="4"
                                                            Background="Transparent" BorderBrush="#B2DFDB" BorderThickness="1">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="#E0F2EE"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Estudiante"     Binding="{Binding NombreEstudiante}" Width="*"/>
                            <DataGridTextColumn Header="Identificación" Binding="{Binding Identificacion}"   Width="120"/>
                            <DataGridTextColumn Header="Grado"          Binding="{Binding NombreGrado}"      Width="90"/>
                            <DataGridTextColumn Header="Grupo"          Binding="{Binding NombreGrupo}"      Width="70"/>
                            <DataGridTextColumn Header="Sede"           Binding="{Binding NombreSede}"       Width="140"/>
                            <DataGridTextColumn Header="Faltas"         Binding="{Binding TotalFaltas}"      Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ── Tab 2: Grados y Grupos ────────────────────────────── -->
            <TabItem Header="Grados y Grupos" x:Name="tabGradosGrupos">
                <Grid Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="White" Padding="20,0"
                            BorderThickness="0,0,0,1" BorderBrush="#E8ECED">
                        <TextBlock Text="GRADOS Y GRUPOS"
                                   FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#999" VerticalAlignment="Center"/>
                    </Border>

                    <DataGrid x:Name="gridGradosGrupos" Grid.Row="1"
                              Style="{StaticResource GridBase}"
                              ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                              AlternatingRowBackground="#F8FAFA">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Grado" Binding="{Binding NombreGrado}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Margin" Value="8,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Grupo" Binding="{Binding NombreGrupo}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Margin" Value="8,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Width="160">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="Estudiantes" FontWeight="SemiBold"
                                                   Foreground="#007864" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding EstudiantesLabel}"
                                                   Foreground="{Binding EstudiantesColor}"
                                                   Margin="8,0" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ── Tab 3: Gráficas ──────────────────────────────────── -->
            <TabItem Header="Gráficas" x:Name="tabGraficas">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F5F7FA">
                    <StackPanel Margin="16,16,16,24">

                        <TextBlock x:Name="lblGraficasTitulo"
                                   FontFamily="Segoe UI" FontSize="11" Foreground="#888"
                                   Margin="0,0,0,14"/>

                        <!-- Fila 1: Donut + Barras por grado ──────── -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Donut: distribución general -->
                            <Border Grid.Column="0" Background="White" CornerRadius="8"
                                    Padding="20" Margin="0,0,10,0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="Distribución general" FontSize="12"
                                               FontFamily="Segoe UI SemiBold" Foreground="#444"
                                               Margin="0,0,0,14"/>
                                    <Canvas x:Name="canvasDonut" Width="160" Height="160"
                                            HorizontalAlignment="Center"/>
                                    <ItemsControl x:Name="lstLeyendaDonut" Margin="0,14,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,3">
                                                    <Border Width="10" Height="10" CornerRadius="2"
                                                            Margin="0,0,8,0" VerticalAlignment="Center"
                                                            Background="{Binding ColorBrush}"/>
                                                    <TextBlock Text="{Binding Label}" FontSize="11"
                                                               Foreground="#555" VerticalAlignment="Center"/>
                                                    <TextBlock Text=" — " FontSize="11" Foreground="#BBB"/>
                                                    <TextBlock Text="{Binding Valor}" FontSize="11"
                                                               FontWeight="SemiBold" Foreground="#333"/>
                                                    <TextBlock Text="{Binding Pct}" FontSize="10"
                                                               Foreground="#999" Margin="4,0,0,0"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Barras horizontales por grado -->
                            <Border Grid.Column="1" Background="White" CornerRadius="8"
                                    Padding="20" Margin="10,0,0,0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="Inasistencias por grado" FontSize="12"
                                               FontFamily="Segoe UI SemiBold" Foreground="#444"
                                               Margin="0,0,0,14"/>
                                    <ItemsControl x:Name="lstBarrasGrado">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,4" Height="28">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="48"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Grado}"
                                                               FontSize="11" Foreground="#555"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <!-- Track + barra fill -->
                                                    <Grid Grid.Column="1" VerticalAlignment="Center">
                                                        <Border Height="16" Background="#F0F4F3" CornerRadius="4"/>
                                                        <Border Height="16" CornerRadius="4"
                                                                HorizontalAlignment="Left"
                                                                Width="{Binding AnchoFalta}"
                                                                Background="{Binding ColorBarra}">
                                                            <Border.ToolTip>
                                                                <TextBlock Text="{Binding Tooltip}"/>
                                                            </Border.ToolTip>
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Grid.Column="2" Text="{Binding FaltaStr}"
                                                               FontSize="11" Foreground="#555"
                                                               VerticalAlignment="Center"
                                                               Margin="8,0,0,0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock x:Name="lblSinDatosGrado"
                                               Text="Sin faltas registradas en el período."
                                               FontSize="11" Foreground="#AAA"
                                               Margin="0,10,0,0" Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Fila 2: Barras verticales por día de la semana ── -->
                        <Border Background="White" CornerRadius="8" Padding="20,16"
                                Margin="0,12,0,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Faltas por día de la semana" FontSize="12"
                                           FontFamily="Segoe UI SemiBold" Foreground="#444"
                                           Margin="0,0,0,14"/>
                                <Canvas x:Name="canvasDias" Height="140"
                                        SizeChanged="CanvasDias_SizeChanged"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

    </Grid>
</Page>
