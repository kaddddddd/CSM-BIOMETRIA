<Page x:Class="CSMBiometricoWPF.Views.Pages.HorariosPage"
     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
     Background="#F5F7FA">

   <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource PanelHeader}">
            <TextBlock Text="Horarios por Sede y Grado" Style="{StaticResource LblTituloHeader}"/>
        </Border>

        <!-- Filtros -->
        <Border Grid.Row="1" Background="White" Padding="16,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.08" Direction="270"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Institución:" VerticalAlignment="Center" FontSize="12"
                           Margin="0,0,8,0" Foreground="#546E7A"/>
                <ComboBox x:Name="cmbInstitucion" Width="180" Height="32"
                          Style="{StaticResource CmbBase}" Margin="0,0,12,0"
                          SelectionChanged="CmbInstitucion_Changed"/>
                <TextBlock Text="Sede:" VerticalAlignment="Center" FontSize="12"
                           Margin="0,0,8,0" Foreground="#546E7A"/>
                <ComboBox x:Name="cmbSede" Width="160" Height="32"
                          Style="{StaticResource CmbBase}" Margin="0,0,12,0"
                          SelectionChanged="CmbSede_Changed"/>
                <TextBlock Text="Grado:" VerticalAlignment="Center" FontSize="12"
                           Margin="0,0,8,0" Foreground="#546E7A"/>
                <ComboBox x:Name="cmbGrado" Width="140" Height="32"
                          Style="{StaticResource CmbBase}" Margin="0,0,12,0"
                          SelectionChanged="CmbGrado_Changed"/>
                <Button x:Name="btnVerExcepciones" Content="📅  Días especiales"
                        Height="32" Padding="12,0" Style="{StaticResource BtnSecundario}"
                        Visibility="Collapsed" Click="BtnVerExcepciones_Click"
                        ToolTip="Definir fechas específicas con horario diferente al semanal"/>
            </StackPanel>
        </Border>

        <!-- Área de horarios -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel>

                <!-- Mensaje vacío -->
                <TextBlock x:Name="lblSeleccioneSede"
                           Text="Seleccione una institución y una sede para ver y editar sus horarios."
                           FontSize="14" Foreground="#9E9E9E"
                           HorizontalAlignment="Center" Margin="0,48,0,0"/>

                <!-- Panel de días -->
                <Border x:Name="pnlHorarios" Visibility="Collapsed"
                        Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>

                        <!-- Aviso de formato -->
                        <Border Background="#FFF8E1" CornerRadius="4" Padding="10,7" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏰" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock FontSize="11.5" Foreground="#795548" VerticalAlignment="Center"
                                           TextWrapping="Wrap">
                                    <Run FontWeight="SemiBold">Formato de hora: HH:mm</Run>
                                    <Run>  —  Ej: 07:30 · 08:00 · 13:30.  Solo se permiten números y el carácter ":"</Run>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Info de ámbito -->
                        <Border x:Name="pnlInfoAmbito" Background="#E8F5F1" CornerRadius="4"
                                Padding="10,6" Margin="0,0,0,8">
                            <TextBlock x:Name="lblInfoAmbito" FontSize="11.5" Foreground="#005040"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- Encabezado de columnas -->
                        <Border Background="#E8F5F1" CornerRadius="4" Padding="8,9" Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="88"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Día"
                                           FontWeight="SemiBold" FontSize="12" Foreground="#005040"/>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center"
                                            ToolTip="Hora exacta a partir de la cual se registra la entrada (HH:mm)">
                                    <TextBlock Text="Hora de entrada" FontWeight="SemiBold" FontSize="12" Foreground="#005040" HorizontalAlignment="Center"/>
                                    <TextBlock Text="(puntual)" FontSize="10" Foreground="#607D8B" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center"
                                            ToolTip="Hasta esta hora la entrada se marca como TARDE (HH:mm)">
                                    <TextBlock Text="Límite tardanza" FontWeight="SemiBold" FontSize="12" Foreground="#005040" HorizontalAlignment="Center"/>
                                    <TextBlock Text="(se marca tarde)" FontSize="10" Foreground="#607D8B" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" HorizontalAlignment="Center"
                                            ToolTip="Después de esta hora ya no se permite el ingreso (HH:mm)">
                                    <TextBlock Text="Cierre de ingreso" FontWeight="SemiBold" FontSize="12" Foreground="#005040" HorizontalAlignment="Center"/>
                                    <TextBlock Text="(sin acceso)" FontSize="10" Foreground="#607D8B" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Grid.Column="5" Text="+ Jornada"
                                           FontWeight="SemiBold" FontSize="11" Foreground="#005040"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           ToolTip="Agregar jornada adicional (ej: jornada tarde)"/>
                            </Grid>
                        </Border>

                        <!-- ── Días de semana ─────────────────────────────── -->

                        <!-- LUNES -->
                        <Border Background="White" CornerRadius="3" Padding="8,5" Margin="0,2">
                            <Grid x:Name="rowLunes">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="88"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="3" Height="18" Background="#009678" CornerRadius="2" Margin="0,0,8,0"/>
                                    <TextBlock Text="Lunes" FontSize="13" FontWeight="SemiBold" Foreground="#263238" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBox x:Name="txtLunesEntrada"  Grid.Column="1" Height="34" Margin="4,0" Style="{StaticResource TxtBase}" MaxLength="5" ToolTip="Hora de entrada puntual  (HH:mm  ej: 07:30)" PreviewTextInput="TimeInput_PreviewTextInput"/>
                                <TextBox x:Name="txtLunesTarde"    Grid.Column="2" Height="34" Margin="4,0" Style="{StaticResource TxtBase}" MaxLength="5" ToolTip="Hasta cuándo se permite entrar tarde  (HH:mm  ej: 08:00)" PreviewTextInput="TimeInput_PreviewTextInput"/>
                                <TextBox x:Name="txtLunesCierre"   Grid.Column="3" Height="34" Margin="4,0" Style="{StaticResource TxtBase}" MaxLength="5" ToolTip="Hora en que se cierra el acceso  (HH:mm  ej: 08:30)" PreviewTextInput="TimeInput_PreviewTextInput"/>
                                <Button Grid.Column="4" Content="Guardar" Height="34" Margin="4,0" Style="{StaticResource BtnPrimario}" FontSize="12" Click="BtnGuardarDia_Click" Tag="LUNES"/>
                                <Button Grid.Column="5" Content="+ Jornada" Height="34" Margin="2,0" Padding="10,0" Style="{StaticResource BtnSecundario}" FontSize="12" ToolTip="Agregar jornada adicional para el Lunes (ej: jornada tarde)" Click="BtnFranjas_Click" Tag="LUNES"/>
                            </Grid>
                        </Border>

                        <!-- MARTES -->
                        <Border Background="#F8FCFA" CornerRadius="3" Padding="8,5" Margin="0,2">
                            <Grid x:Name="rowMartes">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="88"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="3" Height="18" Background="#009678" CornerRadius="2" Margin="0,0,8,0"/>
                                    <TextBlock Text="Martes" FontSize="13" FontWeight="SemiBold" Foreground="#263238" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBox x:Name="txtMartesEntrada"  Grid.Column="1" Height="34" Margin="4,0" Style="{StaticResource TxtBase}" MaxLength="5" ToolTip="Hora de entrada puntual  (HH:mm  ej: 07:30)" PreviewTextInput="TimeInput_PreviewTextInput"/>
                                <TextBox x:Name="txtMartesTarde"    Grid.Column="2" Height="34" Margin="4,0" Style="{StaticResource TxtBase}" MaxLength="5" ToolTip="Hasta cuándo se permite entrar tarde  (HH:mm  ej: 08:00)" PreviewTextInput="TimeInput_PreviewTextInput"/>
                                <TextBox x:Name="txtMartesCierre"   Grid.Column="3" Height="34" Margin="4,0" Style="{StaticResource TxtBase}" MaxLength="5" ToolTip="Hora en que se cierra el acceso  (HH:mm  ej: 08:30)" PreviewTextInput="TimeInput_PreviewTextInput"/>
                                <Button Grid.Column="4" Content="Guardar" Height="34" Margin="4,0" Style="{StaticResource BtnPrimario}" FontSize="12" Click="BtnGuardarDia_Click" Tag="MARTES"/>
                                <Button Grid.Column="5" Content="+ Jornada" Height="34" Margin="2,0" Padding="10,0" Style="{StaticResource BtnSecundario}" FontSize="12" ToolTip="Agregar jornada adicional para el Martes" Click="BtnFranjas_Click" Tag="MARTES"/>
                            </Grid>
                        </Border>

                        <!-- MIERCOLES -->
                        <Border Background="White" CornerRadius="3" Padding="8,5" Margin="0,2">
                            <Grid x:Name="rowMiercoles">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="88"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="3" Height="18" Background="#009678" CornerRadius="2" Margin="0,0,8,0"/>
                                    <TextBlock Text="Miércoles" FontSize="13" FontWeight="SemiBold" Foreground="#263238" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBox x:Name="txtMiercolesEntrada" Grid.Column="1" Height="34" Margin="4,0" Style="{StaticResource TxtBase}" MaxLength="5" ToolTip="Hora de entrada puntual  (HH:mm  ej: 07:30)" PreviewTextInput="TimeInput_PreviewTextInput"/>
                                <TextBox x:Name="txtMiercolesTarde"   Grid.Column="2" Height="34" Margin="4,0" Style="{StaticResource TxtBase}" MaxLength="5" ToolTip="Hasta cuándo se permite entrar tarde  (HH:mm  ej: 08:00)" PreviewTextInput="TimeInput_PreviewTextInput"/>
                                <TextBox x:Name="txtMiercolesCierre"  Grid.Column="3" Height="34" Margin="4,0" Style="{StaticResource TxtBase}" MaxLength="5" ToolTip="Hora en que se cierra el acceso  (HH:mm  ej: 08:30)" PreviewTextInput="TimeInput_PreviewTextInput"/>
                                <Button Grid.Column="4" Content="Guardar" Height="34" Margin="4,0" Style="{StaticResource BtnPrimario}" FontSize="12" Click="BtnGuardarDia_Click" Tag="MIERCOLES"/>
                                <Button Grid.Column="5" Content="+ Jornada" Height="34" Margin="2,0" Padding="10,0" Style="{StaticResource BtnSecundario}" FontSize="12" ToolTip="Agregar jornada adicional para el Miércoles" Click="BtnFranjas_Click" Tag="MIERCOLES"/>
                            </Grid>
                        </Border>

                        <!-- JUEVES -->
                        <Border Background="#F8FCFA" CornerRadius="3" Padding="8,5" Margin="0,2">
                            <Grid x:Name="rowJueves">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="88"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="3" Height="18" Background="#009678" CornerRadius="2" Margin="0,0,8,0"/>
                                    <TextBlock Text="Jueves" FontSize="13" FontWeight="SemiBold" Foreground="#263238" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBox x:Name="txtJuevesEntrada"  Grid.Column="1" Height="34" Margin="4,0" Style="{StaticResource TxtBase}" MaxLength="5" ToolTip="Hora de entrada puntual  (HH:mm  ej: 07:30)" PreviewTextInput="TimeInput_PreviewTextInput"/>
                                <TextBox x:Name="txtJuevesTarde"    Grid.Column="2" Height="34" Margin="4,0" Style="{StaticResource TxtBase}" MaxLength="5" ToolTip="Hasta cuándo se permite entrar tarde  (HH:mm  ej: 08:00)" PreviewTextInput="TimeInput_PreviewTextInput"/>
                                <TextBox x:Name="txtJuevesCierre"   Grid.Column="3" Height="34" Margin="4,0" Style="{StaticResource TxtBase}" MaxLength="5" ToolTip="Hora en que se cierra el acceso  (HH:mm  ej: 08:30)" PreviewTextInput="TimeInput_PreviewTextInput"/>
                                <Button Grid.Column="4" Content="Guardar" Height="34" Margin="4,0" Style="{StaticResource BtnPrimario}" FontSize="12" Click="BtnGuardarDia_Click" Tag="JUEVES"/>
                                <Button Grid.Column="5" Content="+ Jornada" Height="34" Margin="2,0" Padding="10,0" Style="{StaticResource BtnSecundario}" FontSize="12" ToolTip="Agregar jornada adicional para el Jueves" Click="BtnFranjas_Click" Tag="JUEVES"/>
                            </Grid>
                        </Border>

                        <!-- VIERNES -->
                        <Border Background="White" CornerRadius="3" Padding="8,5" Margin="0,2">
                            <Grid x:Name="rowViernes">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="88"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="3" Height="18" Background="#009678" CornerRadius="2" Margin="0,0,8,0"/>
                                    <TextBlock Text="Viernes" FontSize="13" FontWeight="SemiBold" Foreground="#263238" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBox x:Name="txtViernesEntrada" Grid.Column="1" Height="34" Margin="4,0" Style="{StaticResource TxtBase}" MaxLength="5" ToolTip="Hora de entrada puntual  (HH:mm  ej: 07:30)" PreviewTextInput="TimeInput_PreviewTextInput"/>
                                <TextBox x:Name="txtViernesTarde"   Grid.Column="2" Height="34" Margin="4,0" Style="{StaticResource TxtBase}" MaxLength="5" ToolTip="Hasta cuándo se permite entrar tarde  (HH:mm  ej: 08:00)" PreviewTextInput="TimeInput_PreviewTextInput"/>
                                <TextBox x:Name="txtViernesCierre"  Grid.Column="3" Height="34" Margin="4,0" Style="{StaticResource TxtBase}" MaxLength="5" ToolTip="Hora en que se cierra el acceso  (HH:mm  ej: 08:30)" PreviewTextInput="TimeInput_PreviewTextInput"/>
                                <Button Grid.Column="4" Content="Guardar" Height="34" Margin="4,0" Style="{StaticResource BtnPrimario}" FontSize="12" Click="BtnGuardarDia_Click" Tag="VIERNES"/>
                                <Button Grid.Column="5" Content="+ Jornada" Height="34" Margin="2,0" Padding="10,0" Style="{StaticResource BtnSecundario}" FontSize="12" ToolTip="Agregar jornada adicional para el Viernes" Click="BtnFranjas_Click" Tag="VIERNES"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
