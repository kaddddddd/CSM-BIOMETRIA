<Page x:Class="CSMBiometricoWPF.Views.Pages.EstudiantesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F7FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>  <!-- Banner -->
            <RowDefinition Height="50"/>  <!-- Toolbar -->
            <RowDefinition Height="50"/>  <!-- Filtros -->
            <RowDefinition Height="*"/>   <!-- Grid -->
            <RowDefinition Height="35"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Banner -->
        <Border Grid.Row="0" Style="{StaticResource PanelHeader}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#xE902;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                           Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="Gestión de Estudiantes" Style="{StaticResource LblTituloHeader}"/>
            </StackPanel>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource ToolbarAcciones}">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource BtnPrimario}"
                        Background="#009678" Width="100" Height="35" Margin="0,0,8,0"
                        Click="BtnNuevo_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Nuevo" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource BtnSecundario}"
                        Width="110" Height="35" Margin="0,0,8,0"
                        Click="BtnRefrescar_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Refrescar" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource BtnNaranja}"
                        Width="140" Height="35" Margin="0,0,8,0"
                        Click="BtnExportar_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Exportar Excel" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Filtros -->
        <Border Grid.Row="2" Style="{StaticResource BarraFiltros}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Buscar:" Style="{StaticResource LblFiltro}" Margin="0,0,8,0"/>
                <TextBox x:Name="txtBuscar" Width="200" Height="30"
                         Style="{StaticResource TxtBase}"
                         TextChanged="TxtBuscar_Changed" Margin="0,0,16,0"/>
                <TextBlock Text="Estado:" Style="{StaticResource LblFiltro}" Margin="0,0,8,0"/>
                <ComboBox x:Name="cmbEstado" Width="130" Height="30"
                          Style="{StaticResource CmbBase}" Margin="0,0,16,0"
                          SelectionChanged="Filtro_Changed"/>
                <TextBlock Text="Sede:" Style="{StaticResource LblFiltro}" Margin="0,0,8,0"/>
                <ComboBox x:Name="cmbSede" Width="160" Height="30"
                          Style="{StaticResource CmbBase}" Margin="0,0,16,0"
                          SelectionChanged="Filtro_Changed"/>
                <TextBlock Text="Grado:" Style="{StaticResource LblFiltro}" Margin="0,0,8,0"/>
                <ComboBox x:Name="cmbGrado" Width="150" Height="30"
                          Style="{StaticResource CmbBase}"
                          SelectionChanged="Filtro_Changed"/>
            </StackPanel>
        </Border>

        <!-- Grid de estudiantes -->
        <DataGrid x:Name="grid" Grid.Row="3"
                  Style="{StaticResource GridBase}"
                  ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                  MouseDoubleClick="Grid_DoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Identificación" Binding="{Binding Identificacion}" Width="120"/>
                <DataGridTextColumn Header="Nombre completo" Binding="{Binding NombreCompleto}" Width="*"/>
                <DataGridTextColumn Header="Teléfono"        Binding="{Binding Telefono}"       Width="110"/>
                <DataGridTextColumn Header="Sede"            Binding="{Binding NombreSede}"     Width="130"/>
                <DataGridTextColumn Header="Grado"           Binding="{Binding NombreGrado}"    Width="90"/>
                <DataGridTextColumn Header="Grupo"           Binding="{Binding NombreGrupo}"    Width="70"/>
                <DataGridTextColumn Header="Estado"          Binding="{Binding Estado}"         Width="90"/>
                <DataGridTemplateColumn Header="" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="✎" Background="Transparent" BorderThickness="0"
                                        Foreground="#007864" FontSize="16" Cursor="Hand"
                                        Width="36" Click="BtnEditar_Click" Tag="{Binding}"/>
                                <Button Background="Transparent" BorderThickness="0"
                                        Foreground="#C62828" Cursor="Hand"
                                        Width="36" Click="BtnEliminar_Click" Tag="{Binding}">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status bar -->
        <Border Grid.Row="4" Style="{StaticResource StatusBar}">
            <TextBlock x:Name="lblTotal" Text="Mostrando 0 registros"
                       Style="{StaticResource LblStatus}"
                       HorizontalAlignment="Right"/>
        </Border>
    </Grid>
</Page>
