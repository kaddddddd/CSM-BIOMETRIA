<Page x:Class="CSMBiometricoWPF.Views.Pages.PeriodosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F7FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource PanelHeader}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                           Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Períodos Académicos" Style="{StaticResource LblTituloHeader}"/>
                    <TextBlock x:Name="lblSubtitulo" Style="{StaticResource LblSubtituloHeader}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Grid 2×2 de períodos (sin scroll) -->
        <UniformGrid x:Name="pnlPeriodos" Grid.Row="1"
                     Columns="2" Margin="28,20,28,8"/>

        <!-- Footer con botones grandes -->
        <Border Grid.Row="2" Background="White" Padding="32,18"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="btnAgregarPeriodo" Grid.Column="0" HorizontalAlignment="Left"
                        Style="{StaticResource BtnSecundario}"
                        Height="46" Padding="20,0" Click="BtnAgregarPeriodo_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                   VerticalAlignment="Center" Margin="0,0,9,0"/>
                        <TextBlock Text="Agregar período" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="1" Style="{StaticResource BtnSecundario}"
                        Height="46" Padding="22,0" Click="BtnRestablecer_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                   VerticalAlignment="Center" Margin="0,0,9,0"/>
                        <TextBlock Text="Restablecer predeterminados" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="3" Style="{StaticResource BtnPrimario}"
                        Height="46" Padding="26,0" Click="BtnGuardar_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                   VerticalAlignment="Center" Margin="0,0,9,0"/>
                        <TextBlock Text="Guardar cambios" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Page>
