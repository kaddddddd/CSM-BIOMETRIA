<Page x:Class="CSMBiometricoWPF.Views.Pages.InstitucionesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F7FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource PanelHeader}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE825;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                               Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="Institución" Style="{StaticResource LblTituloHeader}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,16,0">
                    <Button x:Name="btnNuevaInst" Style="{StaticResource BtnPrimario}"
                            Height="34" Padding="14,0" Margin="0,0,8,0"
                            Click="BtnNuevaInst_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Nueva Institución" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource BtnSecundario}"
                            Height="34" Padding="14,0" Click="BtnRefrescar_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Refrescar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Contenido scrollable -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20">
            <StackPanel x:Name="pnlContenido" HorizontalAlignment="Stretch"/>
        </ScrollViewer>
    </Grid>
</Page>
