<Page x:Class="CSMBiometricoWPF.Views.Pages.PruebaLectorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#263238">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header oscuro -->
        <Border Grid.Row="0" Background="#1C272C" Padding="20,0">
            <TextBlock Text="🔧  Diagnóstico del Lector"
                       FontFamily="Segoe UI Light" FontSize="20"
                       Foreground="White" VerticalAlignment="Center"/>
        </Border>

        <!-- Contenido -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="🔧" FontSize="72" HorizontalAlignment="Center"
                       Foreground="White" Margin="0,0,0,20"/>
            <TextBlock Text="Diagnóstico del Lector Biométrico"
                       FontFamily="Segoe UI Light" FontSize="24"
                       Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock x:Name="lblEstado" Text="Inicializando..."
                       FontSize="14" Foreground="#80CBC4"
                       HorizontalAlignment="Center" Margin="0,12,0,0"/>

            <Border Margin="0,30,0,0" Background="#1C272C" CornerRadius="6" Padding="24" Width="340">
                <StackPanel>
                    <TextBlock Text="Estado del lector:" Foreground="#80CBC4" FontSize="12" Margin="0,0,0,4"/>
                    <TextBlock x:Name="lblEstadoLector" Text="—"
                               Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                    <Border Height="1" Background="#37474F" Margin="0,12"/>
                    <TextBlock Text="Último mensaje:" Foreground="#80CBC4" FontSize="12" Margin="0,0,0,4"/>
                    <TextBlock x:Name="lblMensaje" Text="—"
                               Foreground="#B2DFDB" FontSize="13" TextWrapping="Wrap"/>
                    <Border Height="1" Background="#37474F" Margin="0,12"/>
                    <!-- Imagen de huella -->
                    <TextBlock Text="Imagen capturada:" Foreground="#80CBC4" FontSize="12" Margin="0,0,0,8"/>
                    <Border BorderBrush="#007864" BorderThickness="2"
                            HorizontalAlignment="Center" Padding="2">
                        <Image x:Name="imgHuella" Width="160" Height="160"
                               Stretch="Uniform"/>
                    </Border>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button x:Name="btnIniciar" Content="▶  Iniciar Prueba"
                        Style="{StaticResource BtnPrimario}"
                        Height="36" Width="150" Margin="0,0,10,0"
                        Click="BtnIniciar_Click"/>
                <Button x:Name="btnDetener" Content="⏹  Detener"
                        Style="{StaticResource BtnPeligro}"
                        Height="36" Width="120" IsEnabled="False"
                        Click="BtnDetener_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
