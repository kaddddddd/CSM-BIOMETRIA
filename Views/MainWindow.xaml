<Window x:Class="CSMBiometricoWPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CSM Educativo - Módulo Biométrico"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="54"/>
        </Grid.RowDefinitions>

        <!-- ══ Área MDI ═══════════════════════════════════════════ -->
        <Grid Grid.Row="0">
            <!-- Dashboard como fondo fijo -->
            <Image x:Name="imgFondo" Stretch="UniformToFill"/>
            <Border Background="#55005040"/>
            <Frame x:Name="frameDashboard"
                   NavigationUIVisibility="Hidden"
                   Background="Transparent"/>
            <!-- Contenedor de ventanas flotantes -->
            <Canvas x:Name="mdiContainer"
                    ClipToBounds="True"
                    Background="{x:Null}"/>
        </Grid>

        <!-- ══ Barra inferior ════════════════════════════════════ -->
        <Border x:Name="barraInferior" Grid.Row="1" Background="White">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="-2"
                                  Opacity="0.12" Direction="90"/>
            </Border.Effect>
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- Menú -->
                    <ColumnDefinition Width="Auto"/>  <!-- Panel Entrada -->
                    <ColumnDefinition Width="Auto"/>  <!-- Buscador -->
                    <ColumnDefinition Width="Auto"/>  <!-- Sep. tabs -->
                    <ColumnDefinition Width="*"/>     <!-- Tabs -->
                    <ColumnDefinition Width="Auto"/>  <!-- Separador -->
                    <ColumnDefinition Width="Auto"/>  <!-- Hora -->
                </Grid.ColumnDefinitions>

                <!-- Botón Menú -->
                <Button x:Name="btnAbrirMenu" Grid.Column="0"
                        Style="{StaticResource BtnMenuPill}"
                        Height="38"
                        Margin="0,0,8,0"
                        Click="BtnAbrirMenu_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Images/icono.png" Width="20" Height="20"
                               VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock Text="Menú" VerticalAlignment="Center"/>
                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                   Foreground="#1ABC9C" VerticalAlignment="Center" Margin="6,1,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Botón Panel de Entrada -->
                <Button x:Name="btnPanelEntrada" Grid.Column="1"
                        Background="Transparent"
                        Foreground="#444444"
                        BorderThickness="0"
                        Padding="12,0"
                        Height="38"
                        Cursor="Hand"
                        Click="BtnPanelEntrada_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Panel Entrada" FontFamily="Segoe UI" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Buscador -->
                <Border x:Name="borderBuscar" Grid.Column="2"
                        Background="#F0F0F0"
                        CornerRadius="14"
                        Margin="10,8,0,8"
                        Padding="12,0" Width="220">
                    <TextBox x:Name="txtBuscar"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#333333"
                             FontFamily="Segoe UI"
                             FontSize="12"
                             VerticalAlignment="Center"
                             GotFocus="TxtBuscar_GotFocus"
                             LostFocus="TxtBuscar_LostFocus"
                             KeyDown="TxtBuscar_KeyDown"
                             TextChanged="TxtBuscar_TextChanged"/>
                </Border>

                <!-- Popup sugerencias buscador -->
                <Popup x:Name="popupBuscar" Grid.Column="2"
                       PlacementTarget="{Binding ElementName=borderBuscar}"
                       Placement="Top"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                    <Border Background="White" Width="220"
                            CornerRadius="4,4,0,0"
                            BorderThickness="1" BorderBrush="#DDDDDD">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="0"
                                              Opacity="0.2" Color="Black"/>
                        </Border.Effect>
                        <ListBox x:Name="lstSugerencias"
                                 BorderThickness="0"
                                 MaxHeight="220"
                                 MouseUp="LstSugerencias_MouseUp"
                                 KeyDown="LstSugerencias_KeyDown">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="10,7"/>
                                    <Setter Property="Cursor"  Value="Hand"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E8F5F2"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#D0EFEA"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icono}"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14"
                                                   Width="24" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Nombre}" FontSize="13"
                                                   Foreground="#263238" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Popup>

                <!-- Separador antes de tabs -->
                <Border Grid.Column="3"
                        Width="1" Background="#DDDDDD"
                        Margin="6,12"/>

                <!-- Área de tabs de módulos abiertos -->
                <ScrollViewer Grid.Column="4"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              VerticalAlignment="Center">
                    <StackPanel x:Name="pnlTabs"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"/>
                </ScrollViewer>

                <!-- Separador vertical -->
                <Border Grid.Column="5"
                        Width="1" Background="#DDDDDD"
                        Margin="0,12"/>

                <!-- Hora -->
                <TextBlock x:Name="lblHora" Grid.Column="6"
                           FontFamily="Segoe UI" FontSize="13"
                           Foreground="#333333"
                           VerticalAlignment="Center"
                           Margin="10,0,6,0"/>
            </Grid>
        </Border>

        <!-- ══ POPUP DEL MENÚ ════════════════════════════════════ -->
        <Popup x:Name="popupMenu"
               Grid.Row="1"
               Placement="Top"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <Border CornerRadius="10,10,0,0"
                    BorderThickness="2,2,2,0"
                    BorderBrush="#1ABC9C"
                    Width="400"
                    ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="22" ShadowDepth="5"
                                      Opacity="0.28" Direction="270" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="178"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── Panel izquierdo ────────────────────────────── -->
                    <Grid Grid.Column="0" Background="White">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header: avatar + nombre -->
                        <Border Grid.Row="0" Background="#1ABC9C" Padding="14,12">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="34" Height="34" CornerRadius="17"
                                        Background="#40FFFFFF" BorderBrush="#65FFFFFF"
                                        BorderThickness="2"
                                        VerticalAlignment="Center" Margin="0,0,10,0">
                                    <TextBlock Text="&#xE77B;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="16" Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="lblMenuNombreUsuario"
                                           Foreground="White"
                                           FontFamily="Segoe UI SemiBold"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="148"/>
                            </StackPanel>
                        </Border>

                        <!-- Categorías del menú -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MaxHeight="340">
                            <StackPanel x:Name="pnlMenuItems" Margin="0,4,0,6"/>
                        </ScrollViewer>
                    </Grid>

                    <!-- ── Panel derecho ──────────────────────────────── -->
                    <Border x:Name="pnlMenuDerPanel" Grid.Column="1" Background="#F5F7F8"
                            BorderThickness="1,0,0,0" BorderBrush="#D0D8DC">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>    <!-- Logo / Submenú -->
                                <RowDefinition Height="Auto"/> <!-- Cerrar Sesión (siempre) -->
                            </Grid.RowDefinitions>

                            <!-- Área de contenido (logo por defecto, submenú al hover) -->
                            <Grid Grid.Row="0">
                                <!-- Logo + nombre institución -->
                                <StackPanel x:Name="pnlMenuDerDefault"
                                            VerticalAlignment="Center"
                                            Margin="14,16,14,8">
                                    <Image x:Name="imgLogoPopup"
                                           Width="72" Height="72"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8"/>
                                    <TextBlock x:Name="lblInstPopup"
                                               TextAlignment="Center"
                                               FontFamily="Segoe UI Semibold"
                                               FontSize="11"
                                               Foreground="#333333"
                                               TextWrapping="Wrap"
                                               HorizontalAlignment="Center"
                                               MaxWidth="155"/>
                                </StackPanel>

                                <!-- Submenú al pasar cursor (se puebla en código) -->
                                <StackPanel x:Name="pnlMenuDerSubmenu"
                                            Visibility="Collapsed"
                                            VerticalAlignment="Top"
                                            Margin="0,8,0,8"/>
                            </Grid>

                            <!-- Cerrar Sesión: SIEMPRE visible -->
                            <Border Grid.Row="1"
                                    BorderThickness="0,1,0,0" BorderBrush="#D0D8DC"
                                    Padding="12,10,12,12">
                                <Button Height="36" HorizontalAlignment="Stretch"
                                        Click="BtnCerrarSesion_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background"      Value="#F5A623"/>
                                            <Setter Property="Foreground"      Value="White"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Cursor"          Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="bd"
                                                                Background="{TemplateBinding Background}"
                                                                CornerRadius="6" Padding="10,0">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="bd" Property="Background"
                                                                        Value="#E09415"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="&#xE72E;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="13" VerticalAlignment="Center"
                                                   Margin="0,0,6,0"/>
                                        <TextBlock Text="Cerrar Sesión"
                                                   FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Popup>

    </Grid>
</Window>
