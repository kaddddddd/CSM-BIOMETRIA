<Window x:Class="CSMBiometricoWPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CSM Educativo - Módulo Biométrico"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <!-- Imagen de fondo -->
        <Image x:Name="imgFondo" Stretch="UniformToFill"/>
        <!-- Overlay verde oscuro semitransparente -->
        <Border Background="#55005040"/>

        <!-- Frame de contenido (ocupa todo menos la barra inferior) -->
        <Frame x:Name="frameContenido"
               NavigationUIVisibility="Hidden"
               Background="Transparent"
               Margin="0,0,0,54"/>

        <!-- ══════════════════════════════════════════
             BARRA INFERIOR
             ══════════════════════════════════════════ -->
        <Border VerticalAlignment="Bottom" Height="54" Background="White">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="-2" Opacity="0.12" Direction="90"/>
            </Border.Effect>
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- Botón Menú (con logo) -->
                    <ColumnDefinition Width="Auto"/>  <!-- Botón Panel Entrada -->
                    <ColumnDefinition Width="Auto"/>  <!-- Búsqueda -->
                    <ColumnDefinition Width="*"/>     <!-- Espacio -->
                    <ColumnDefinition Width="Auto"/>  <!-- Separador -->
                    <ColumnDefinition Width="Auto"/>  <!-- Hora -->
                </Grid.ColumnDefinitions>

                <!-- Botón Menú: ovalado, blanco, logo CSM + texto negro -->
                <Button x:Name="btnAbrirMenu" Grid.Column="0"
                        Background="White"
                        Foreground="#222222"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1"
                        Padding="14,0"
                        Height="38"
                        Cursor="Hand"
                        Click="BtnAbrirMenu_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="19"/>
                        </Style>
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Images/icono.png" Width="26" Height="26"
                               VerticalAlignment="Center" Margin="0,0,7,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="Menú" FontFamily="Segoe UI SemiBold" FontSize="13"
                                   VerticalAlignment="Center" Foreground="#222222"/>
                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                   VerticalAlignment="Center" Foreground="#555555" Margin="5,1,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Botón Panel de Entrada -->
                <Button x:Name="btnPanelEntrada" Grid.Column="1"
                        Background="Transparent"
                        Foreground="#444444"
                        BorderThickness="0"
                        Padding="12,0"
                        Height="38"
                        Cursor="Hand"
                        Margin="8,0,0,0"
                        Click="BtnPanelEntrada_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Panel Entrada" FontFamily="Segoe UI" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Buscador -->
                <Border x:Name="borderBuscar" Grid.Column="2"
                        Background="#F0F0F0"
                        CornerRadius="14"
                        Margin="10,8,0,8"
                        Padding="12,0" Width="220">
                    <TextBox x:Name="txtBuscar"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#333333"
                             FontFamily="Segoe UI"
                             FontSize="12"
                             VerticalAlignment="Center"
                             GotFocus="TxtBuscar_GotFocus"
                             LostFocus="TxtBuscar_LostFocus"
                             KeyDown="TxtBuscar_KeyDown"
                             TextChanged="TxtBuscar_TextChanged"/>
                </Border>

                <!-- Popup de sugerencias -->
                <Popup x:Name="popupBuscar" Grid.Column="2"
                       PlacementTarget="{Binding ElementName=borderBuscar}"
                       Placement="Top"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                    <Border Background="White" Width="220"
                            CornerRadius="4,4,0,0"
                            BorderThickness="1" BorderBrush="#DDDDDD">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="0"
                                              Opacity="0.2" Color="Black"/>
                        </Border.Effect>
                        <ListBox x:Name="lstSugerencias"
                                 BorderThickness="0"
                                 MaxHeight="220"
                                 MouseUp="LstSugerencias_MouseUp"
                                 KeyDown="LstSugerencias_KeyDown">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="10,7"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E8F5F2"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#D0EFEA"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Icono}" FontSize="14"
                                                   Width="24" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Nombre}" FontSize="13"
                                                   Foreground="#263238" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Popup>

                <!-- Separador vertical -->
                <Border Grid.Column="4"
                        Width="1" Background="#DDDDDD"
                        Margin="0,12"/>

                <!-- Hora -->
                <TextBlock x:Name="lblHora" Grid.Column="5"
                           FontFamily="Segoe UI" FontSize="13"
                           Foreground="#333333"
                           VerticalAlignment="Center"
                           Margin="10,0,6,0"/>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════
             POPUP DEL MENÚ
             ══════════════════════════════════════════ -->
        <Popup x:Name="popupMenu"
               PlacementTarget="{Binding ElementName=btnAbrirMenu}"
               Placement="Top"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Slide">

            <Border Background="White" Width="270"
                    CornerRadius="6,6,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0"
                                      Opacity="0.30" Color="Black"/>
                </Border.Effect>

                <StackPanel>
                    <!-- Header: usuario + institución -->
                    <Border Background="#007864"
                            CornerRadius="6,6,0,0"
                            Padding="16,14">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Images/icono.png"
                                   Width="42" Height="42"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="lblNombreUsuario"
                                           FontFamily="Segoe UI SemiBold"
                                           FontSize="13" Foreground="White"/>
                                <TextBlock x:Name="lblInstitucion"
                                           FontFamily="Segoe UI" FontSize="10"
                                           Foreground="#B0E8DE"
                                           TextWrapping="Wrap" MaxWidth="170"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Ítems de navegación (construidos en código) -->
                    <ScrollViewer MaxHeight="420"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="pnlMenu"/>
                    </ScrollViewer>

                    <!-- Footer: cerrar sesión -->
                    <Border BorderThickness="0,1,0,0"
                            BorderBrush="#E0E0E0"
                            Padding="12,10">
                        <Button Style="{StaticResource BtnPeligro}"
                                Height="34"
                                HorizontalAlignment="Stretch"
                                Click="BtnCerrarSesion_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xF3B1;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Cerrar Sesión" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Border>
                </StackPanel>
            </Border>
        </Popup>

    </Grid>
</Window>
