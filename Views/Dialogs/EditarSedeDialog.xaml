<Window x:Class="CSMBiometricoWPF.Views.Dialogs.EditarSedeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sede"
        Width="540" Height="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#007864" Padding="18,0">
            <TextBlock x:Name="lblTitulo" Text="Nueva Sede"
                       FontFamily="Segoe UI Light" FontSize="18"
                       Foreground="White" VerticalAlignment="Center"/>
        </Border>

        <!-- Campos -->
        <Grid Grid.Row="1" Margin="20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Nombre -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Nombre Sede *"
                       FontSize="11" Foreground="#757575" Margin="0,0,0,4"/>
            <TextBox Grid.Row="1" Grid.Column="0" x:Name="txtNombre"
                     Height="34" Style="{StaticResource TxtBase}" Margin="0,0,0,12"/>

            <!-- Institución -->
            <TextBlock x:Name="lblInstitucionLabel" Grid.Row="0" Grid.Column="2" Text="Institución *"
                       FontSize="11" Foreground="#757575" Margin="0,0,0,4"/>
            <ComboBox Grid.Row="1" Grid.Column="2" x:Name="cmbInstitucion"
                      Height="34" Style="{StaticResource CmbBase}" Margin="0,0,0,12"/>

            <!-- Dirección -->
            <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                       Text="Dirección" FontSize="11" Foreground="#757575" Margin="0,0,0,4"/>
            <TextBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                     x:Name="txtDireccion" Height="34"
                     Style="{StaticResource TxtBase}" Margin="0,0,0,12"/>
        </Grid>

        <!-- CheckBox estado (fuera del Grid para alinearlo debajo) -->
        <CheckBox x:Name="chkEstado" Content="Sede activa"
                  IsChecked="True" FontSize="13"
                  Grid.Row="1" VerticalAlignment="Bottom" Margin="20,0,0,8"/>

        <!-- Botones -->
        <Border Grid.Row="2" Background="White" Padding="16,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="-1" Opacity="0.08" Direction="90"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="Cancelar" Style="{StaticResource BtnSecundario}"
                        Width="90" Height="34" Margin="0,0,10,0"
                        Click="BtnCancelar_Click"/>
                <Button Content="Guardar" Style="{StaticResource BtnPrimario}"
                        Width="100" Height="34"
                        Click="BtnGuardar_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
