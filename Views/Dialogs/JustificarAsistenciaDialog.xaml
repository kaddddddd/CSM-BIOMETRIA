<Window x:Class="CSMBiometricoWPF.Views.Dialogs.JustificarAsistenciaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Justificar registro" Width="460" Height="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False" Background="#F5F7FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="56"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#007864" Padding="20,0">
            <TextBlock Text="Justificar registro de asistencia"
                       FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold"
                       Foreground="White" VerticalAlignment="Center"/>
        </Border>

        <!-- Tarjeta info del registro -->
        <Border Grid.Row="1" Margin="18,14,18,0"
                Background="White" CornerRadius="8"
                BorderBrush="#C8E6E0" BorderThickness="1">
            <Grid Margin="14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Nombre y fecha -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="lblNombre"
                               FontSize="13" FontWeight="SemiBold" Foreground="#263238"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="lblFecha"
                               FontSize="11" Foreground="#546E7A" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Badge estado -->
                <Border x:Name="bdgEstado" Grid.Column="1"
                        CornerRadius="10" Padding="12,4" VerticalAlignment="Center"
                        Background="#FFEBEE">
                    <TextBlock x:Name="lblEstado" FontSize="11" FontWeight="Bold"
                               Foreground="#C62828"/>
                </Border>
            </Grid>
        </Border>

        <!-- Motivo -->
        <Grid Grid.Row="2" Margin="18,14,18,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Opción de corrección de estado (FUERA_DE_HORARIO y TARDE) -->
            <Border x:Name="pnlCorreccion" Grid.Row="0"
                    Background="#E8F5E9" CornerRadius="6" Padding="12,8"
                    Margin="0,0,0,10" Visibility="Collapsed">
                <CheckBox x:Name="chkCorregirATiempo"
                          Content="Corregir estado a  A TIEMPO  (el estudiante sí asistió)"
                          FontSize="12" Foreground="#2E7D32" FontWeight="SemiBold"/>
            </Border>

            <!-- Campo de franja/jornada -->
            <StackPanel Grid.Row="1" Margin="0,0,0,10">
                <TextBlock Text="Franja / Jornada  (dejar vacío para quitar)"
                           FontSize="11" FontWeight="SemiBold" Foreground="#546E7A"
                           Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" BorderBrush="#B2DFDB" BorderThickness="1.5"
                            CornerRadius="6" Background="White">
                        <TextBox x:Name="txtFranja" BorderThickness="0" Background="Transparent"
                                 FontSize="13" Foreground="#263238" Padding="10,6"
                                 VerticalContentAlignment="Center" MaxLength="80"/>
                    </Border>
                    <Button Grid.Column="1" Content="✕" Width="34" Height="34" Margin="6,0,0,0"
                            Style="{StaticResource BtnSecundario}" ToolTip="Quitar franja"
                            Click="BtnLimpiarFranja_Click"/>
                </Grid>
            </StackPanel>

            <TextBlock Grid.Row="2"
                       Text="Observación / motivo"
                       FontSize="11" FontWeight="SemiBold" Foreground="#546E7A"
                       Margin="0,0,0,6"/>

            <Border Grid.Row="3" BorderBrush="#B2DFDB" BorderThickness="1.5"
                    CornerRadius="6" Background="White">
                <TextBox x:Name="txtObservacion"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" MaxLength="200"
                         BorderThickness="0" Background="Transparent"
                         FontSize="13" Foreground="#263238" Padding="10,8"
                         VerticalContentAlignment="Top"/>
            </Border>

            <TextBlock Grid.Row="4" x:Name="lblContador"
                       FontSize="10" Foreground="#90A4AE"
                       HorizontalAlignment="Right" Margin="0,4,2,0"
                       Text="0 / 200 caracteres"/>
        </Grid>

        <!-- Botones -->
        <Border Grid.Row="3" Background="White" Padding="18,0"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="Cancelar" Style="{StaticResource BtnSecundario}"
                        Width="95" Height="34" Margin="0,0,10,0"
                        Click="BtnCancelar_Click"/>
                <Button Content="Guardar" Style="{StaticResource BtnPrimario}"
                        Width="110" Height="34"
                        Click="BtnGuardar_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
