<Window x:Class="CSMBiometricoWPF.Views.Dialogs.JustificarAsistenciaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Justificar registro" Width="440" Height="270"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False" Background="#F5F7FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#007864" Padding="18,0">
            <TextBlock Text="Justificar registro de asistencia"
                       FontFamily="Segoe UI Light" FontSize="17"
                       Foreground="White" VerticalAlignment="Center"/>
        </Border>

        <!-- Contenido -->
        <StackPanel Grid.Row="1" Margin="20,14">
            <!-- Info del registro -->
            <Border Background="#E0F2EE" CornerRadius="5" Padding="12,8" Margin="0,0,0,14">
                <TextBlock x:Name="lblInfo" FontSize="12" Foreground="#00695C"
                           TextWrapping="Wrap" FontWeight="SemiBold"/>
            </Border>

            <TextBlock Text="Motivo de la justificación:" FontSize="11"
                       Foreground="#546E7A" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtObservacion" Height="70"
                     TextWrapping="Wrap" AcceptsReturn="False"
                     VerticalScrollBarVisibility="Auto" MaxLength="200"
                     Style="{StaticResource TxtBase}" FontSize="13"
                     ToolTip="Ej: Cita médica, Permiso del acudiente, Calamidad doméstica…"/>
        </StackPanel>

        <!-- Botones -->
        <Border Grid.Row="2" Background="White" Padding="16,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="-1" Opacity="0.08" Direction="90"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="Cancelar" Style="{StaticResource BtnSecundario}"
                        Width="90" Height="34" Margin="0,0,10,0"
                        Click="BtnCancelar_Click"/>
                <Button Content="Guardar" Style="{StaticResource BtnPrimario}"
                        Width="100" Height="34"
                        Click="BtnGuardar_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
