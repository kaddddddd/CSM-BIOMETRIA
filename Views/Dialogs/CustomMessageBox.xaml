<Window x:Class="CSMBiometricoWPF.Views.Dialogs.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height"
        Width="420">

    <Window.Resources>
        <!-- Botón primario (fondo sólido teal) -->
        <Style x:Key="MsgBtnPrimary" TargetType="Button">
            <Setter Property="Background"     Value="#007864"/>
            <Setter Property="Foreground"     Value="White"/>
            <Setter Property="BorderBrush"    Value="#007864"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Height"         Value="36"/>
            <Setter Property="MinWidth"       Value="90"/>
            <Setter Property="Padding"        Value="18,0"/>
            <Setter Property="FontFamily"     Value="Segoe UI"/>
            <Setter Property="FontSize"       Value="13"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="Margin"         Value="6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón secundario (borde teal, fondo blanco) -->
        <Style x:Key="MsgBtnSecondary" TargetType="Button" BasedOn="{StaticResource MsgBtnPrimary}">
            <Setter Property="Background"  Value="White"/>
            <Setter Property="Foreground"  Value="#007864"/>
            <Setter Property="BorderBrush" Value="#007864"/>
        </Style>
    </Window.Resources>

    <!-- Marco exterior con sombra -->
    <Border x:Name="OuterBorder" Background="White" CornerRadius="8"
            BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="5" Opacity="0.35" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>   <!-- Cabecera -->
                <RowDefinition Height="*"/>    <!-- Cuerpo -->
                <RowDefinition Height="64"/>   <!-- Botones -->
            </Grid.RowDefinitions>

            <!-- ── Cabecera ── -->
            <Border x:Name="HeaderBorder" Grid.Row="0"
                    Background="#007864" CornerRadius="8,8,0,0" Padding="20,0">
                <TextBlock x:Name="TitleText"
                           FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold"
                           Foreground="White" VerticalAlignment="Center"/>
            </Border>

            <!-- ── Cuerpo (icono + mensaje) ── -->
            <StackPanel Grid.Row="1" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="24,20,24,20">

                <!-- Icono circular -->
                <Grid Width="50" Height="50" Margin="0,0,18,0" VerticalAlignment="Center">
                    <Ellipse x:Name="IconEllipse"/>
                    <TextBlock x:Name="IconText"
                               FontFamily="Segoe UI" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>

                <!-- Texto del mensaje -->
                <TextBlock x:Name="MessageText"
                           FontFamily="Segoe UI" FontSize="13"
                           Foreground="#424242"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           MaxWidth="294"
                           LineHeight="21"/>
            </StackPanel>

            <!-- Separador -->
            <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"/>

            <!-- ── Botones ── -->
            <StackPanel x:Name="ButtonsPanel" Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
        </Grid>
    </Border>
</Window>
