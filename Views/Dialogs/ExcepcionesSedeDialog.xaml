<Window x:Class="CSMBiometricoWPF.Views.Dialogs.ExcepcionesSedeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Días con horario especial"
        Width="760" Height="660"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" MinWidth="600" MinHeight="460"
        Background="#F5F7FA"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#007864" Padding="18,0">
            <DockPanel VerticalAlignment="Center">
                <TextBlock x:Name="lblTitulo" Text="Días con horario especial"
                           FontFamily="Segoe UI Light" FontSize="18"
                           Foreground="White" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Contenido -->
        <Grid Grid.Row="1" Margin="16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Bloque explicativo -->
            <Border Grid.Row="0" Background="#E3F2FD" CornerRadius="4" Padding="12,9" Margin="0,0,0,10">
                <TextBlock FontSize="11.5" Foreground="#37474F" TextWrapping="Wrap">
                    Defina fechas con horario diferente al semanal normal. Cada excepción puede aplicar
                    a <Run FontWeight="SemiBold">una sede</Run>, a un
                    <Run FontWeight="SemiBold">grado específico</Run>, o a
                    <Run FontWeight="SemiBold">todas las sedes de la institución</Run>.
                </TextBlock>
            </Border>

            <!-- Formulario nueva excepción -->
            <Border Grid.Row="1" Background="White" CornerRadius="4" Padding="12,10" Margin="0,0,0,10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.08" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Registrar nuevo día especial" FontSize="12" FontWeight="SemiBold"
                               Foreground="#007864" Margin="0,0,0,8"/>

                    <!-- Fila 1: fecha + descripción + botón -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Fecha:" VerticalAlignment="Center"
                                   FontSize="12" Margin="0,0,8,0"/>
                        <DatePicker x:Name="dpFecha" Grid.Column="1" Height="30" Margin="0,0,10,0"
                                    SelectedDateFormat="Short" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtDescripcion" Grid.Column="2" Height="30" Margin="0,0,10,0"
                                 Style="{StaticResource TxtBase}"
                                 ToolTip="Motivo del día especial (ej: Reunión de profesores, Día cultural)"/>
                        <Button Grid.Column="3" Content="+ Agregar fecha" Height="30" Padding="12,0"
                                Style="{StaticResource BtnPrimario}" Click="BtnAgregarExcepcion_Click"/>
                    </Grid>

                    <!-- Fila 2: ámbito selector -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Ámbito:" VerticalAlignment="Center"
                                   FontSize="12" Margin="0,0,8,0" Foreground="#546E7A"/>
                        <RadioButton x:Name="rdoSede" Grid.Column="1" Content="Esta sede"
                                     IsChecked="True" VerticalAlignment="Center" Margin="0,0,16,0"
                                     FontSize="12" Checked="Ambito_Changed"/>
                        <RadioButton x:Name="rdoTodasSedes" Grid.Column="2" Content="Todas las sedes"
                                     VerticalAlignment="Center" Margin="0,0,16,0"
                                     FontSize="12" Checked="Ambito_Changed"/>
                        <RadioButton x:Name="rdoGrado" Grid.Column="3" Content="Grado específico:"
                                     VerticalAlignment="Center" Margin="0,0,8,0"
                                     FontSize="12" Checked="Ambito_Changed"/>
                        <ComboBox x:Name="cmbGradoExc" Grid.Column="4" Width="130" Height="28"
                                  Style="{StaticResource CmbBase}" IsEnabled="False"
                                  DisplayMemberPath="NombreGrado" Margin="0,0,16,0"/>
                        <TextBlock x:Name="lblAmbitoInfo" Grid.Column="5"
                                   VerticalAlignment="Center" FontSize="10.5" Foreground="#888"
                                   Text="Se aplicará solo a esta sede"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Height="1" Background="#E0E0E0" Margin="0,0,0,10"/>

            <!-- Panel dividido -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Lista de fechas especiales -->
                <Border Grid.Column="0" Background="White" CornerRadius="4" Padding="0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.08" Direction="270"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#E8F5F1" CornerRadius="4,4,0,0" Padding="10,8">
                            <StackPanel>
                                <TextBlock Text="📅  Fechas especiales registradas"
                                           FontWeight="SemiBold" FontSize="12" Foreground="#005040"/>
                                <TextBlock Text="Seleccione una para ver/editar sus horarios"
                                           FontSize="10.5" Foreground="#607D8B" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <ListBox x:Name="lstExcepciones" Grid.Row="1"
                                 BorderThickness="0" Padding="4"
                                 SelectionChanged="LstExcepciones_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="2,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding FechaStr}" FontWeight="SemiBold" FontSize="13"/>
                                            <Border Background="#E8F5F1" CornerRadius="3" Padding="4,1" Margin="6,0,0,0">
                                                <TextBlock Text="{Binding AlcanceLabel}" FontSize="10" Foreground="#005040"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Descripcion}" FontSize="11.5" Foreground="#555"/>
                                        <TextBlock Text="{Binding FranjasCount}" FontSize="10.5" Foreground="#007864"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Panel de horarios del día especial seleccionado -->
                <Border Grid.Column="2" Background="White" CornerRadius="4">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.08" Direction="270"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#E8F5F1" CornerRadius="4,4,0,0" Padding="10,8">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="🕐  Horarios del día especial"
                                               FontWeight="SemiBold" FontSize="12" Foreground="#005040"/>
                                    <TextBlock Text="Entrada · Límite tardanza · Cierre de ingreso"
                                               FontSize="10.5" Foreground="#607D8B" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button x:Name="btnEliminarExcepcion" DockPanel.Dock="Right"
                                        Content="Eliminar fecha" Height="24" Padding="8,0"
                                        FontSize="10.5" Margin="6,0,0,0" VerticalAlignment="Center"
                                        Style="{StaticResource BtnPeligro}"
                                        Visibility="Collapsed" Click="BtnEliminarExcepcion_Click"/>
                            </DockPanel>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8,6">
                            <StackPanel>
                                <TextBlock x:Name="lblSeleccioneExcepcion"
                                           Text="👈  Seleccione una fecha especial de la lista para ver y editar sus horarios."
                                           FontSize="11" Foreground="#aaa" TextWrapping="Wrap"/>
                                <StackPanel x:Name="pnlFranjasExcepcion"/>
                                <TextBlock x:Name="lblSinFranjas"
                                           Text="Sin horarios definidos. Use el formulario de abajo para agregar."
                                           FontSize="11" Foreground="#aaa" Visibility="Collapsed"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="2" x:Name="pnlEncabezadoFranjas"
                                Background="#F9F9F9" Padding="8,8" Margin="4,4"
                                CornerRadius="4" Visibility="Collapsed">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.07" Direction="270"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Agregar horario  (solo se permiten números y el carácter :)"
                                           FontSize="10.5" Foreground="#607D8B" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="68"/>
                                        <ColumnDefinition Width="68"/>
                                        <ColumnDefinition Width="68"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="txtFranjaNombre"  Grid.Column="0" Height="32" Margin="0,0,4,0"
                                             Style="{StaticResource TxtBase}" ToolTip="Nombre del horario (ej: Jornada mañana)" Text="Jornada"/>
                                    <TextBox x:Name="txtFranjaEntrada" Grid.Column="1" Height="32" Margin="0,0,4,0"
                                             Style="{StaticResource TxtBase}" ToolTip="Hora entrada HH:mm"
                                             MaxLength="5" PreviewTextInput="TimeInput_PreviewTextInput"/>
                                    <TextBox x:Name="txtFranjaTarde"   Grid.Column="2" Height="32" Margin="0,0,4,0"
                                             Style="{StaticResource TxtBase}" ToolTip="Límite tardanza HH:mm"
                                             MaxLength="5" PreviewTextInput="TimeInput_PreviewTextInput"/>
                                    <TextBox x:Name="txtFranjaCierre"  Grid.Column="3" Height="32" Margin="0,0,4,0"
                                             Style="{StaticResource TxtBase}" ToolTip="Cierre de ingreso HH:mm"
                                             MaxLength="5" PreviewTextInput="TimeInput_PreviewTextInput"/>
                                    <Button Grid.Column="4" Content="+ Agregar" Height="32" Padding="12,0"
                                            Style="{StaticResource BtnPrimario}" FontSize="12"
                                            ToolTip="Agregar este horario al día especial" Click="BtnAgregarFranja_Click"/>
                                </Grid>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="68"/>
                                        <ColumnDefinition Width="68"/>
                                        <ColumnDefinition Width="68"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Nombre" FontSize="9" Foreground="#999" Margin="3,0,0,0"/>
                                    <TextBlock Grid.Column="1" Text="Entrada" FontSize="9" Foreground="#999" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Tardanza" FontSize="9" Foreground="#999" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="Cierre" FontSize="9" Foreground="#999" HorizontalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="3" x:Name="pnlBtnAgregarFranja" Padding="8,4" Visibility="Collapsed">
                            <TextBlock Text="Las horas deben ir en orden: Entrada ≤ Tardanza ≤ Cierre."
                                       FontSize="10" Foreground="#888" TextWrapping="Wrap"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Pie -->
        <Border Grid.Row="2" Background="White" Padding="16,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="-1" Opacity="0.08" Direction="90"/>
            </Border.Effect>
            <Button Content="Cerrar" Style="{StaticResource BtnSecundario}"
                    Width="100" Height="34" HorizontalAlignment="Right" VerticalAlignment="Center"
                    Click="BtnCerrar_Click"/>
        </Border>
    </Grid>
</Window>
